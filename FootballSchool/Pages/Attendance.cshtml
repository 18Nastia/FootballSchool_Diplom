@page
@model FootballSchool.Pages.AttendanceModel
@{
    ViewData["Title"] = "Учет посещаемости";
}

@section Styles {
    <link rel="stylesheet" href="~/css/attendance.css" asp-append-version="true" />
}

<div class="attendance-page">
    <div class="attendance-content">

        <h1 class="page-title">Учет и статистика посещаемости</h1>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success mb-4" style="background-color: #dcfce7; border: 1px solid #bbf7d0; color: #166534; padding: 16px; border-radius: 8px;">
                <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            </div>
        }

        <div class="tabs">
            <a href="?ViewMode=Daily&FilterTeamId=@Model.FilterTeamId" class="tab-link @(Model.ViewMode == "Daily" ? "active" : "")">
                <i class="fas fa-clipboard-check"></i> Журнал тренировок
            </a>
            <a href="?ViewMode=Report&FilterTeamId=@Model.FilterTeamId" class="tab-link @(Model.ViewMode == "Report" ? "active" : "")">
                <i class="fas fa-chart-bar"></i> Статистика и отчеты
            </a>
        </div>

        @if (Model.ViewMode == "Daily")
        {
            <form method="get" class="filters">
                <input type="hidden" name="ViewMode" value="Daily" />

                <div class="filter-group">
                    <label class="filter-label">Выберите группу</label>
                    <select asp-for="FilterTeamId" asp-items="Model.TeamList" class="select-input" onchange="this.form.submit()"></select>
                </div>

                <div class="filter-group">
                    <label class="filter-label">Дата</label>
                    <input type="date" asp-for="FilterDate" class="date-input" onchange="this.form.submit()">
                </div>

                @if (Model.AvailableTrainings != null && Model.AvailableTrainings.Any())
                {
                    <div class="filter-group">
                        <label class="filter-label">Выберите занятие</label>
                        <select asp-for="SelectedTrainingId" class="select-input" onchange="this.form.submit()">
                            <option value="">-- Выберите тренировку --</option>
                            @foreach (var t in Model.AvailableTrainings)
                            {
                                var time = t.TimeTraining.ToString("HH:mm");
                                var plan = string.IsNullOrEmpty(t.PlanTraining) ? "Тренировка" : t.PlanTraining;
                                var statusIcon = Model.FilledTrainingIds.Contains(t.TrainingId) ? "✅" : "⏳";
                                <option value="@t.TrainingId">@statusIcon @time - @plan</option>
                            }
                        </select>
                    </div>
                }
            </form>

            @if (Model.AvailableTrainings == null || !Model.AvailableTrainings.Any())
            {
                <div class="no-data-alert">
                    <i class="fas fa-calendar-times" style="font-size: 24px; margin-bottom: 12px; display: block;"></i>
                    <strong>Тренировок не найдено.</strong><br />
                    На выбранную дату для данной группы тренировки не запланированы.
                </div>
            }
            else if (!Model.SelectedTrainingId.HasValue)
            {
                <div class="info-alert">
                    <i class="fas fa-hand-pointer" style="font-size: 24px; margin-bottom: 12px; display: block; color: #64748b;"></i>
                    <strong>Выберите тренировку</strong><br />
                    В выпадающем списке занятия отмечены иконками (✅ - заполнено, ⏳ - ожидает). Выберите занятие для продолжения.
                </div>
            }
            else
            {
                @if (Model.IsAlreadyFilled)
                {
                    <div style="background-color: #ecfdf5; border: 1px solid #a7f3d0; color: #065f46; padding: 16px; border-radius: 8px; margin-bottom: 24px;">
                        <i class="fas fa-check-circle me-2"></i> <strong>Журнал заполнен!</strong> Посещаемость для этой тренировки уже была отмечена. Вы можете внести изменения и сохранить их снова.
                    </div>
                }
                else
                {
                    <div style="background-color: #fffbeb; border: 1px solid #fde68a; color: #92400e; padding: 16px; border-radius: 8px; margin-bottom: 24px;">
                        <i class="fas fa-exclamation-circle me-2"></i> <strong>Журнал не заполнен.</strong> Отметьте присутствующих учеников и нажмите "Сохранить".
                    </div>
                }

                <div class="stats-box">
                    <div class="stats-title">Информация о тренировке</div>
                    <div class="stats-text mb-2">@Model.TrainingInfo</div>
                    <div class="stats-text" id="live-stats">Присутствует: <strong>0 из 0 учеников (0%)</strong></div>
                </div>

                <form method="post" asp-page-handler="Save">
                    <input type="hidden" name="ViewMode" value="Daily" />
                    <input type="hidden" asp-for="SelectedTrainingId" />
                    <input type="hidden" asp-for="FilterTeamId" />
                    <input type="hidden" asp-for="FilterDate" />

                    <div class="action-buttons">
                        <button type="button" class="btn-mark-all" onclick="markAllPresent()">
                            <i class="fas fa-check-circle"></i>
                            Отметить всех "Был"
                        </button>
                        <button type="button" class="btn-mark-none" onclick="markAllAbsent()">
                            <i class="fas fa-times-circle"></i>
                            Никого нет
                        </button>
                    </div>

                    <div class="attendance-table">
                        <div class="table-header">
                            <div>Ученик</div>
                            <div>Статус</div>
                            <div>Комментарий</div>
                        </div>

                        @if (!Model.AttendanceItems.Any())
                        {
                            <div class="p-4 text-center text-muted">В данной группе пока нет учеников.</div>
                        }

                        @for (int i = 0; i < Model.AttendanceItems.Count; i++)
                        {
                            <div class="table-row student-row">
                                <input type="hidden" asp-for="AttendanceItems[i].StudentId" />

                                <div>
                                    <div class="mobile-label">Ученик</div>
                                    <div class="student-name">@Model.AttendanceItems[i].StudentName</div>
                                </div>

                                <div>
                                    <div class="mobile-label">Статус</div>
                                    <div class="status-group">
                                        <label class="radio-option">
                                            <input type="radio" asp-for="AttendanceItems[i].Status" value="Был" onchange="updateStatistics()" />
                                            <span>Был</span>
                                        </label>

                                        <label class="radio-option absent">
                                            <input type="radio" asp-for="AttendanceItems[i].Status" value="Не был" onchange="updateStatistics()" />
                                            <span>Не был</span>
                                        </label>
                                    </div>
                                </div>

                                <div>
                                    <div class="mobile-label">Комментарий</div>
                                    <input type="text" asp-for="AttendanceItems[i].Comment" class="comment-input" placeholder="Комментарий (необязательно)">
                                </div>
                            </div>
                        }
                    </div>

                    <div class="bottom-actions">
                        <button type="submit" class="btn-save">
                            <i class="fas fa-save"></i>
                            Сохранить журнал
                        </button>
                    </div>
                </form>
            }
        }
        else if (Model.ViewMode == "Report")
        {
            <form method="get" class="filters mb-4">
                <input type="hidden" name="ViewMode" value="Report" />

                <div class="filter-group">
                    <label class="filter-label">Выберите группу</label>
                    <select asp-for="FilterTeamId" asp-items="Model.TeamList" class="select-input" onchange="this.form.submit()"></select>
                </div>

                <div class="filter-group">
                    <label class="filter-label">Период для журнала</label>
                    <select asp-for="ReportPeriod" class="select-input" onchange="this.form.submit()">
                        <option value="week">За последние 7 дней</option>
                        <option value="month">За последний месяц</option>
                        <option value="year">За последний год</option>
                        <option value="all">За все время</option>
                    </select>
                </div>
            </form>

            <div class="mb-4">
                <a href="?handler=ExportReport&teamId=@(Model.FilterTeamId ?? 0)&period=@Model.ReportPeriod"
                   class="btn-save"
                   style="background-color: #10b981; text-decoration: none; width: fit-content; display: inline-flex;">
                    <i class="fas fa-file-excel"></i> Экспорт в Excel
                </a>
            </div>

            @if (!Model.JournalTrainings.Any() || !Model.JournalRows.Any())
            {
                <div class="p-4 text-center text-muted empty-report-alert" style="background-color: #f8fafc; border-radius: 8px;">
                    В выбранном периоде не найдено занятий или в группе нет учеников.
                </div>
            }
            else
            {
                <div class="journal-wrapper">
                    <div class="journal-table">
                        <table class="attendance-journal-table">
                            <thead>
                                <tr>
                                    <th class="sticky-col">ФИО</th>
                                    @foreach (var tr in Model.JournalTrainings)
                                    {
                                        <th>
                                            <div>@tr.DateTraining.ToString("dd.MM")</div>
                                            <div class="journal-time">@tr.TimeTraining.ToString("HH:mm")</div>
                                        </th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.JournalRows)
                                {
                                    <tr>
                                        <td class="sticky-col student-col">@row.StudentName</td>
                                        @foreach (var mark in row.Marks)
                                        {
                                            <td class="mark-cell">
                                                @if (mark == "✔")
                                                {
                                                    <span class="mark-present">✔</span>
                                                }
                                                else if (mark == "✖")
                                                {
                                                    <span class="mark-absent">✖</span>
                                                }
                                                else
                                                {
                                                    <span class="mark-empty">—</span>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td class="sticky-col total-label">ИТОГО</td>
                                    @foreach (var total in Model.JournalTotals)
                                    {
                                        <td class="total-cell">@total</td>
                                    }
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            }
        }

    </div>
</div>

@section Scripts {
    <script>
        function updateStatistics() {
            const rows = document.querySelectorAll('.student-row');
            const totalStudents = rows.length;

            if (totalStudents === 0) return;

            let presentCount = 0;
            rows.forEach(row => {
                const presentRadio = row.querySelector('input[type="radio"][value="Был"]');
                if (presentRadio && presentRadio.checked) {
                    presentCount++;
                }
            });

            const percentage = Math.round((presentCount / totalStudents) * 100);

            const statsElement = document.getElementById('live-stats');
            if (statsElement) {
                statsElement.innerHTML = `Присутствует: <strong>${presentCount} из ${totalStudents} учеников (${percentage}%)</strong>`;
            }
        }

        function markAllPresent() {
            document.querySelectorAll('.student-row input[type="radio"][value="Был"]').forEach(r => r.checked = true);
            updateStatistics();
        }

        function markAllAbsent() {
            document.querySelectorAll('.student-row input[type="radio"][value="Не был"]').forEach(r => r.checked = true);
            updateStatistics();
        }

        document.addEventListener('DOMContentLoaded', updateStatistics);
    </script>
}