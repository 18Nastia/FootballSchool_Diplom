@page
@model FootballSchool.Pages.TrainingResultsModel
@{
    ViewData["Title"] = "Результаты тренировок";
}

@section Styles {
    <link rel="stylesheet" href="~/css/training-results.css" asp-append-version="true" />
}

<div class="training-results-page">
    <div class="training-results-content">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success mb-4"><i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger mb-4"><i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]</div>
        }

        <div class="header">
            <h1>Результаты тренировок</h1>
            <div class="header-actions">
                <a href="?handler=Export&FilterTeamId=@Model.FilterTeamId" class="btn btn-secondary" title="Сводка (список текущей таблицы)">
                    <i class="fas fa-file-excel" style="color: #10b981;"></i> Сводка
                </a>
                <a href="?handler=ExportDetailed&teamId=@Model.FilterTeamId" class="btn btn-secondary" title="Подробный отчет со всей историей результатов">
                    <i class="fas fa-list" style="color: #10b981;"></i> Полный отчет
                </a>
            </div>
        </div>

        <div class="content-with-sidebar">
            <div class="main-content-area">

                <form method="get" class="team-filter-form">
                    <label class="team-filter-label">Выберите группу</label>
                    <select asp-for="FilterTeamId" asp-items="Model.TeamList" class="form-control" onchange="this.form.submit()">
                        <option value="">-- Все доступные группы --</option>
                    </select>
                </form>

                <div class="table-container">
                    <table class="results-table">
                        <thead>
                            <tr>
                                <th>Ученик</th>
                                <th>Группа</th>
                                <th>Последний тест</th>
                                <th>Прогресс (за месяц)</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.StudentsList == null || !Model.StudentsList.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted">Учеников не найдено.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var student in Model.StudentsList)
                                {
                                    <tr>
                                        <td data-label="Ученик">
                                            <div class="student-cell">
                                                <div class="avatar">@student.Initials</div>
                                                <div class="student-info">
                                                    <h3>@student.FullName</h3>
                                                    <p>@student.Age лет</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td data-label="Группа">
                                            <span class="group-badge">@student.TeamName</span>
                                        </td>
                                        <td data-label="Последний тест">
                                            <div class="test-info">
                                                <h4>@student.LatestTestName</h4>
                                                <div class="date">@student.LatestTestDate</div>
                                                <div class="result">@student.LatestTestResult</div>
                                            </div>
                                        </td>
                                        <td data-label="Прогресс">
                                            <div class="progress-chart" title="Посещаемость за 30 дней: @student.ProgressPercentage%">
                                                <div class="progress-fill" style="width: @student.ProgressPercentage%; background: @(student.ProgressPercentage >= 75 ? "#10b981" : student.ProgressPercentage >= 50 ? "#f59e0b" : "#ef4444");"></div>
                                            </div>
                                            <div class="progress-mobile-text">@student.ProgressPercentage%</div>
                                        </td>
                                        <td data-label="Действия">
                                            <div class="action-buttons">
                                                <button type="button"
                                                        class="icon-btn"
                                                        title="Добавить/Посмотреть результат"
                                                        data-name="@student.FullName"
                                                        onclick="openSidebar(@student.StudentId, this.getAttribute('data-name'))">
                                                    <i class="fas fa-chart-pie"></i>
                                                </button>
                                                <a href="/ChildProfile/@student.StudentId" class="icon-btn" title="Профиль ученика">
                                                    <i class="fas fa-chevron-right"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <button class="toggle-sidebar-btn" type="button" onclick="toggleSidebar()">
        <i class="fas fa-chevron-left"></i>
    </button>

    <aside class="right-sidebar" id="rightSidebar">

        <div class="sidebar-header-wrapper">
            <h2 id="sidebarTitle">Выберите ученика</h2>
            <button type="button" class="close-sidebar" onclick="toggleSidebar()">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <div class="sidebar-tabs">
            <button type="button" class="sidebar-tab active" onclick="switchSidebarTab('history', this)">История и графики</button>
            <button type="button" class="sidebar-tab" onclick="switchSidebarTab('add', this)">Внести результат</button>
        </div>

        <div class="sidebar-content">

            <div id="tab-history" class="sidebar-tab-pane active">
                <div class="form-group mb-4">
                    <label>Выберите тип графика</label>
                    <select class="form-control" id="chartTypeSelect" onchange="renderChartAndHistory()">
                        <option value="Скорость">Скорость (бег 30м)</option>
                        <option value="Техника">Техника владения</option>
                        <option value="Сила удара">Сила удара</option>
                        <option value="Точность">Точность передач</option>
                        <option value="Выносливость">Выносливость (челночный бег)</option>
                    </select>
                </div>

                <div class="chart-canvas-container">
                    <canvas id="progressChart"></canvas>
                </div>

                <div class="history-block">
                    <div class="history-block-header">
                        <h4>История результатов</h4>
                        <a href="#" id="exportStudentHistoryBtn" class="btn btn-secondary btn-small">
                            <i class="fas fa-file-excel" style="color: #10b981;"></i> Экспорт истории
                        </a>
                    </div>

                    <div class="history-table-wrap">
                        <table class="history-table">
                            <thead>
                                <tr>
                                    <th>Дата</th>
                                    <th>Тип</th>
                                    <th>Результат</th>
                                    <th style="width: 70px;">Действия</th>
                                </tr>
                            </thead>
                            <tbody id="historyTableBody">
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div id="tab-add" class="sidebar-tab-pane">
                <form method="post" asp-page-handler="SaveResult">
                    <input type="hidden" asp-for="SelectedStudentId" id="selectedStudentId" />
                    <input type="hidden" asp-for="EditingResultId" id="editingResultId" value="0" />

                    <div class="form-group">
                        <label>Тип теста</label>
                        <select asp-for="TestType" class="form-control" id="formTestType">
                            <option value="Скорость">Скорость (бег 30м)</option>
                            <option value="Техника">Техника владения</option>
                            <option value="Сила удара">Сила удара</option>
                            <option value="Точность">Точность передач</option>
                            <option value="Выносливость">Выносливость (челночный бег)</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Дата</label>
                        <input asp-for="TestDate" type="date" class="form-control" id="formTestDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" required>
                    </div>

                    <div class="form-group">
                        <label>Результат</label>
                        <div class="result-input-group">
                            <input asp-for="TestResult" type="text" class="form-control" id="formTestResult" placeholder="Например: 9.5" required>
                            <select asp-for="ResultUnit" class="form-control" id="formResultUnit">
                                <option value="сек">сек</option>
                                <option value="балл">балл</option>
                                <option value="км/ч">км/ч</option>
                                <option value="%">%</option>
                                <option value="раз">раз</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Примечания к тесту</label>
                        <textarea asp-for="TestNotes" class="form-control" id="formTestNotes" placeholder="Слабая левая нога, отличный рывок..."></textarea>
                    </div>

                    <div class="form-group mt-4">
                        <label>Общий комментарий тренера</label>
                        <textarea asp-for="CoachComments" class="form-control" id="formCoachComments" placeholder="Добавьте развернутый комментарий о прогрессе..."></textarea>
                    </div>

                    <div class="form-actions-row">
                        <button type="button" class="btn btn-secondary w-100 justify-center-mobile" onclick="clearAddForm()">
                            <i class="fas fa-eraser"></i> Очистить
                        </button>
                        <button type="submit" class="btn btn-primary w-100 justify-center-mobile">
                            <i class="fas fa-save"></i> <span id="saveBtnText">Сохранить</span>
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </aside>

    <form id="deleteForm" method="post" asp-page-handler="DeleteResult" style="display: none;">
        <input type="hidden" name="resultId" id="deleteResultId" />
    </form>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script type="application/json" id="studentsHistoryData">
        @Html.Raw(Model != null && !string.IsNullOrEmpty(Model.StudentsHistoryJson) ? Model.StudentsHistoryJson : "{}")
    </script>

    <script>
        let studentsHistory = {};
        try {
            const dataElement = document.getElementById('studentsHistoryData');
            if (dataElement && dataElement.textContent.trim() !== '') {
                const rawText = dataElement.textContent.trim();
                if (rawText.startsWith('{') || rawText.startsWith('[')) {
                    studentsHistory = JSON.parse(rawText);
                }
            }
        } catch (e) {
            console.error("Ошибка парсинга истории студентов:", e);
        }

        let chartInstance = null;

        function toggleSidebar() {
            const sidebar = document.getElementById('rightSidebar');
            const toggleBtn = document.querySelector('.toggle-sidebar-btn');

            sidebar.classList.toggle('open');
            toggleBtn.classList.toggle('open');
        }

        function switchSidebarTab(tabId, btn) {
            document.querySelectorAll('.sidebar-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.sidebar-tab-pane').forEach(p => p.classList.remove('active'));

            if (btn) {
                btn.classList.add('active');
            }

            document.getElementById('tab-' + tabId).classList.add('active');

            if (tabId === 'history') {
                renderChartAndHistory();
            }
        }

        function openSidebar(studentId, studentName) {
            document.getElementById('selectedStudentId').value = studentId;
            document.getElementById('sidebarTitle').innerHTML = `<span style='color:#2563EB'>${studentName}</span>`;

            const exportBtn = document.getElementById('exportStudentHistoryBtn');
            if (exportBtn) {
                exportBtn.href = `?handler=ExportDetailed&studentId=${studentId}`;
            }

            clearAddForm();

            const historyBtn = document.querySelector('.sidebar-tabs button:first-child');
            switchSidebarTab('history', historyBtn);

            const sidebar = document.getElementById('rightSidebar');
            const toggleBtn = document.querySelector('.toggle-sidebar-btn');

            if (!sidebar.classList.contains('open')) {
                sidebar.classList.add('open');
                toggleBtn.classList.add('open');
            }
        }

        function renderChartAndHistory() {
            const studentId = document.getElementById('selectedStudentId').value;
            const selectedType = document.getElementById('chartTypeSelect').value;

            const data = studentsHistory[studentId] || [];

            const tbody = document.getElementById('historyTableBody');
            tbody.innerHTML = '';

            [...data].reverse().forEach(item => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${item.date}</td>
                    <td>${item.type}</td>
                    <td><span class="val-badge">${item.value} ${item.unit}</span></td>
                    <td>
                        <div class="history-actions">
                            <button type="button" class="history-btn edit" onclick="editResult(${studentId}, ${item.id})" title="Изменить"><i class="fas fa-edit"></i></button>
                            <button type="button" class="history-btn delete" onclick="deleteResult(${item.id})" title="Удалить"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                `;
                tbody.appendChild(tr);
            });

            if (data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted">Нет результатов</td></tr>';
            }

            const chartData = data.filter(d => d.type === selectedType);
            const labels = chartData.map(d => d.date);
            const values = chartData.map(d => d.value);
            const unitLabel = chartData.length > 0 ? chartData[0].unit : '';

            const ctx = document.getElementById('progressChart').getContext('2d');

            if (chartInstance) {
                chartInstance.destroy();
            }

            chartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: `${selectedType} (${unitLabel})`,
                        data: values,
                        borderColor: '#2563eb',
                        backgroundColor: 'rgba(37, 99, 235, 0.1)',
                        borderWidth: 2,
                        pointBackgroundColor: '#1d4ed8',
                        pointRadius: 4,
                        fill: true,
                        tension: 0.3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top'
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: false,
                            suggestedMin: values.length ? (Math.min(...values) > 0 ? Math.min(...values) * 0.8 : 0) : 0
                        }
                    }
                }
            });
        }

        function editResult(studentId, resultId) {
            const studentData = studentsHistory[studentId] || [];
            const item = studentData.find(d => d.id === resultId);

            if (!item) return;

            document.getElementById('editingResultId').value = item.id;
            document.getElementById('formTestType').value = item.type;

            const dateParts = item.date.split('.');
            if (dateParts.length === 3) {
                document.getElementById('formTestDate').value = `${dateParts[2]}-${dateParts[1]}-${dateParts[0]}`;
            }

            document.getElementById('formTestResult').value = item.value;
            document.getElementById('formResultUnit').value = item.unit || 'сек';
            document.getElementById('formTestNotes').value = item.note || '';
            document.getElementById('formCoachComments').value = item.comment || '';

            document.getElementById('saveBtnText').innerText = 'Обновить';

            const addBtn = document.querySelector('.sidebar-tabs button:nth-child(2)');
            switchSidebarTab('add', addBtn);
        }

        function clearAddForm() {
            document.getElementById('editingResultId').value = '0';
            document.getElementById('formTestType').value = 'Скорость';
            document.getElementById('formTestDate').value = new Date().toISOString().split('T')[0];
            document.getElementById('formTestResult').value = '';
            document.getElementById('formResultUnit').value = 'сек';
            document.getElementById('formTestNotes').value = '';
            document.getElementById('formCoachComments').value = '';
            document.getElementById('saveBtnText').innerText = 'Сохранить';
        }

        function deleteResult(resultId) {
            if (confirm('Вы уверены, что хотите удалить этот результат тестирования? Действие необратимо.')) {
                document.getElementById('deleteResultId').value = resultId;
                document.getElementById('deleteForm').submit();
            }
        }
    </script>
}