            border-left: 2px solid #edf2f7;
        }

        .event-day {
            border-radius: 8px;
            padding: 12px 16px;
            background: white;
            color: #2c3e50;
            font-size: 13px;
            position: relative;
            box-shadow: 0 2px 6px rgba(0,0,0,0.04);
            border: 1px solid #edf2f7;
            border-left-width: 4px;
            border-left-style: solid;
