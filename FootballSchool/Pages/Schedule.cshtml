<div class="schedule-page">
    <div class="main-content">

        <form method="get" id="filterForm" class="controls-wrapper">
            <input type="hidden" asp-for="CurrentDate" id="CurrentDate" value="@(safeCurrentDate.ToString("yyyy-MM-dd"))" />
            <input type="hidden" asp-for="ViewType" id="ViewType" />

            <div class="d-flex align-items-center gap-3">
                <div class="view-toggle">
                    <button type="button" class="toggle-btn @(Model.ViewType == "week" ? "active" : "")" onclick="setView('week')">Неделя</button>
                    <button type="button" class="toggle-btn @(Model.ViewType == "day" ? "active" : "")" onclick="setView('day')">День</button>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <button type="button" class="add-btn d-none d-md-flex" data-bs-toggle="modal" data-bs-target="#trainingModal" onclick="prepareAddModal()">
                        <i class="fas fa-plus"></i> Добавить
                    </button>
                }
            </div>

            <div class="date-navigation">
                <button type="button" class="btn-nav" onclick="changeDate(-1)"><i class="fas fa-chevron-left"></i></button>

                <div class="current-date-display fw-bold mx-3">
                    @if (Model.ViewType == "week")
                    {
                        @($"{safeStartOfWeek:dd MMM} - {safeEndOfWeek:dd MMM yyyy}")
                    }
                    else
                    {
                        @safeCurrentDate.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("ru-RU"))
                    }
                </div>

                <button type="button" class="btn-nav" onclick="changeDate(1)"><i class="fas fa-chevron-right"></i></button>
            </div>

            <div class="filters">
                <i class="fas fa-filter" style="color: #bdc3c7;"></i>
                <select class="filter-select" asp-for="FilterBranchId" asp-items="Model.BranchList" onchange="this.form.submit()">
                    <option value="">Все филиалы</option>
                </select>
                <select class="filter-select" asp-for="FilterTeamId" asp-items="Model.TeamList" onchange="this.form.submit()">
                    <option value="">Все группы</option>
                </select>
            </div>

            @if (User.IsInRole("Admin"))
            {
                <button type="button" class="add-btn d-md-none w-100 justify-content-center mt-2" data-bs-toggle="modal" data-bs-target="#trainingModal" onclick="prepareAddModal()">
                    <i class="fas fa-plus"></i> Добавить тренировку
                </button>
            }
        </form>

        <div class="calendar @(Model.ViewType == "week" ? "active" : "")">
            <div class="calendar-header">
                @for (int i = 0; i < 7; i++)
                {
                    var dayDate = safeStartOfWeek.AddDays(i);
                    <div class="day-header">
                        <div class="day-name">@dayDate.ToString("ddd", new System.Globalization.CultureInfo("ru-RU"))</div>
                        <div class="day-date">@dayDate.ToString("dd MMM")</div>
                    </div>
                }
            </div>

            <div class="days-grid">
                @for (int i = 0; i < 7; i++)
                {
                    var currentDayOfWeek = daysOfWeek[i];
                    <div class="day-column">
                        @if (currentWeekTrainings.ContainsKey(currentDayOfWeek))
                        {
                            var dayTrainings = currentWeekTrainings[currentDayOfWeek].OrderBy(t => t.TimeTraining).ToList();

                            foreach (var training in dayTrainings)
                            {
                                var startTime = training.TimeTraining;
                                var endTime = startTime.AddHours(1).AddMinutes(30);

                                var coach = training.Coach;
                                var coachId = coach?.CoachId ?? 0;
                                var coachName = coach != null ? $"{coach.SurnameCoach} {coach.NameCoach[0]}." : "Не назначен";
                                var facilityName = training.Facility?.NameFacility ?? "Зал не указан";
                                var teamName = training.Team?.CategoryTeam ?? "Без группы";
                                var title = !string.IsNullOrEmpty(training.PlanTraining) ? training.PlanTraining : "Тренировка";
                                var safeTitle = title.Replace("'", "\\'");

                                string colorClass = GetEventColorClass(coachId);

                                <div class="event @colorClass">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <div class="event-actions">
                                            <button type="button" class="btn-icon" data-bs-toggle="modal" data-bs-target="#trainingModal" onclick="event.stopPropagation(); prepareEditModal(@training.TrainingId, '@training.DateTraining.ToString("yyyy-MM-dd")', '@training.TimeTraining.ToString("HH:mm")', @(training.CoachId), @(training.TeamId), @(training.FacilityId), '@safeTitle')">
                                                <i class="fas fa-pen"></i>
                                            </button>
                                            <form method="post" asp-page-handler="Delete" asp-route-id="@training.TrainingId" style="display:inline;" onsubmit="event.stopPropagation(); return confirm('Удалить эту тренировку?');">
                                                <button type="submit" class="btn-icon">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }

                                    <div class="fw-bold" style="font-size: 13px; color: #2980b9; margin-bottom: 4px;">
                                        @startTime.ToString("HH:mm") - @endTime.ToString("HH:mm")
                                    </div>
                                    <div class="fw-bold mb-2" style="font-size: 12px; line-height: 1.3; padding-right: 20px;">@title</div>

                                    <div style="font-size: 11px; line-height: 1.4; color: #7f8c8d; display: flex; flex-direction: column; gap: 3px;">
                                        <div title="@facilityName"><i class="fas fa-map-marker-alt event-icon"></i>@facilityName</div>
                                        <div title="@coachName"><i class="fas fa-user event-icon"></i>@coachName</div>
                                        <div title="@teamName"><i class="fas fa-users event-icon"></i>@teamName</div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center text-muted" style="font-size: 11px; margin-top: 10px; opacity: 0.6;">
                                Нет занятий
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="day-view @(Model.ViewType == "day" ? "active" : "")">
            <div class="date-header">@safeCurrentDate.ToString("dd MMMM, dddd", new System.Globalization.CultureInfo("ru-RU"))</div>

            <div class="timeline">
                @for (int hour = 8; hour <= 22; hour++)
                {
                    var hourTrainings = currentDayTrainings.Where(t => t.TimeTraining.Hour == hour).ToList();

                    <div class="time-slot-day">
                        <span class="time-label">@hour.ToString("00"):00</span>
                        <div class="event-container">
                            @if (!hourTrainings.Any())
                            {

                            }
                            else
                            {
                                @foreach (var training in hourTrainings)
                                {
                                    var startTime = training.TimeTraining;
                                    var endTime = startTime.AddHours(1).AddMinutes(30);
                                    var coachId = training.Coach?.CoachId ?? 0;
                                    var coachName = training.Coach != null ? $"{training.Coach.SurnameCoach} {training.Coach.NameCoach[0]}." : "Не назначен";
                                    var facilityName = training.Facility?.NameFacility ?? "Зал не указан";
                                    var teamName = training.Team?.CategoryTeam ?? "Без группы";
                                    var title = !string.IsNullOrEmpty(training.PlanTraining) ? training.PlanTraining : "Тренировка";
                                    var safeTitle = title.Replace("'", "\\'");
                                    var colorClass = GetEventColorClass(coachId);

                                    <div class="event-day @colorClass">
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <div class="event-actions">
                                                <button type="button" class="btn-icon" data-bs-toggle="modal" data-bs-target="#trainingModal" onclick="event.stopPropagation(); prepareEditModal(@training.TrainingId, '@training.DateTraining.ToString("yyyy-MM-dd")', '@training.TimeTraining.ToString("HH:mm")', @(training.CoachId), @(training.TeamId), @(training.FacilityId), '@safeTitle')">
                                                    <i class="fas fa-pen"></i>
                                                </button>
                                                <form method="post" asp-page-handler="Delete" asp-route-id="@training.TrainingId" style="display:inline;" onsubmit="event.stopPropagation(); return confirm('Удалить тренировку?');">
                                                    <button type="submit" class="btn-icon"><i class="fas fa-trash"></i></button>
                                                </form>
                                            </div>
                                        }

                                        <div class="fw-bold text-muted mb-1" style="font-size: 11px;">@startTime.ToString("HH:mm") - @endTime.ToString("HH:mm")</div>
                                        <div class="fw-bold mb-2" style="font-size: 14px;">@title</div>

                                        <div class="d-flex flex-wrap gap-3" style="font-size: 12px; color: #7f8c8d;">
                                            <div><i class="fas fa-users"></i> @teamName</div>
                                            <div><i class="fas fa-map-marker-alt"></i> @facilityName</div>
                                            <div><i class="fas fa-whistle"></i> @coachName</div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="legend">
            <div class="legend-title">Тренеры (на экране):</div>
            <div class="legend-items">
                @if (uniqueCoaches.Any())
                {
                    foreach (var coach in uniqueCoaches)
                    {
                        var coachId = coach.CoachId;
                        var coachName = $"{coach.SurnameCoach} {coach.NameCoach[0]}.";
                        <div class="legend-item">
                            <span class="legend-dot @GetLegendDot(coachId)"></span>
                            <span>@coachName</span>
                        </div>
                    }
                }
                else
                {
                    <span class="text-muted" style="font-size: 13px;">Нет данных для отображения</span>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="trainingModal" tabindex="-1" aria-labelledby="trainingModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Save" id="trainingForm">
                <div class="modal-header">
                    <h5 class="modal-title" id="trainingModalLabel">Новая тренировка</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="ModalTraining.TrainingId" id="ModalTraining_TrainingId" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ModalTraining.DateTraining" class="form-label">Дата</label>
                            <input asp-for="ModalTraining.DateTraining" type="date" class="form-control" required id="ModalTraining_DateTraining" value="@(safeCurrentDate.ToString("yyyy-MM-dd"))" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ModalTraining.TimeTraining" class="form-label">Время начала</label>
                            <input asp-for="ModalTraining.TimeTraining" type="time" class="form-control" required id="ModalTraining_TimeTraining" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ModalTraining.CoachId" class="form-label">Тренер</label>
                        <select asp-for="ModalTraining.CoachId" asp-items="Model.CoachList" class="form-select" required id="ModalTraining_CoachId">
                            <option value="">-- Выберите тренера --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ModalTraining.TeamId" class="form-label">Группа (Команда)</label>
                        <select asp-for="ModalTraining.TeamId" asp-items="Model.TeamList" class="form-select" required id="ModalTraining_TeamId">
                            <option value="">-- Выберите группу --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ModalTraining.FacilityId" class="form-label">Помещение (Зал)</label>
                        <select asp-for="ModalTraining.FacilityId" asp-items="Model.FacilityList" class="form-select" required id="ModalTraining_FacilityId">
                            <option value="">-- Выберите помещение --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ModalTraining.PlanTraining" class="form-label">Тема / План тренировки</label>
                        <input asp-for="ModalTraining.PlanTraining" class="form-control" id="ModalTraining_PlanTraining" placeholder="Например: Отработка пасов" />
                    </div>

                    <input type="hidden" name="isBulkAdd" id="isBulkAdd" value="false" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary" onclick="document.getElementById('isBulkAdd').value='false';">Сохранить</button>
                    <button type="submit" class="btn btn-success" id="bulkAddBtn" onclick="document.getElementById('isBulkAdd').value='true';">Сохранить и добавить еще</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function setView(viewType) {
            document.getElementById('ViewType').value = viewType;
            document.getElementById('filterForm').submit();
        }

        function changeDate(direction) {
            let currentDateInput = document.getElementById('CurrentDate');
            let date = new Date(currentDateInput.value);
            let viewType = document.getElementById('ViewType').value;

            let daysToAdd = (viewType === 'week' ? 7 : 1) * direction;
            date.setDate(date.getDate() + daysToAdd);

            let year = date.getFullYear();
            let month = String(date.getMonth() + 1).padStart(2, '0');
            let day = String(date.getDate()).padStart(2, '0');

            currentDateInput.value = `${year}-${month}-${day}`;
            document.getElementById('filterForm').submit();
        }

        function prepareAddModal() {
            document.getElementById('trainingForm').reset();
            document.getElementById('ModalTraining_TrainingId').value = 0;
            document.getElementById('ModalTraining_DateTraining').value = document.getElementById('CurrentDate').value;
            document.getElementById('trainingModalLabel').innerText = 'Новая тренировка';
            document.getElementById('bulkAddBtn').style.display = 'inline-block';
        }

        function prepareEditModal(id, date, time, coachId, teamId, facilityId, plan) {
            document.getElementById('ModalTraining_TrainingId').value = id;
            document.getElementById('ModalTraining_DateTraining').value = date;
            document.getElementById('ModalTraining_TimeTraining').value = time;
            document.getElementById('ModalTraining_CoachId').value = coachId;
            document.getElementById('ModalTraining_TeamId').value = teamId;
            document.getElementById('ModalTraining_FacilityId').value = facilityId;
            document.getElementById('ModalTraining_PlanTraining').value = plan;

            document.getElementById('trainingModalLabel').innerText = 'Редактировать тренировку';
            document.getElementById('bulkAddBtn').style.display = 'none';
        }
    </script>

    @if (TempData["ShowAddModal"] as bool? == true)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                prepareAddModal();

                document.getElementById('ModalTraining_DateTraining').value = '@TempData["BulkDate"]';
                document.getElementById('ModalTraining_TeamId').value = '@TempData["BulkTeamId"]';
                document.getElementById('ModalTraining_FacilityId').value = '@TempData["BulkFacilityId"]';
                document.getElementById('ModalTraining_CoachId').value = '@TempData["BulkCoachId"]';
                document.getElementById('ModalTraining_TimeTraining').value = '';

                let btn = document.createElement('button');
                btn.setAttribute('data-bs-toggle', 'modal');
                btn.setAttribute('data-bs-target', '#trainingModal');
                btn.style.display = 'none';
                document.body.appendChild(btn);
                btn.click();
                btn.remove();
            });
        </script>
    }
}