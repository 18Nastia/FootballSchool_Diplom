@page
@model FootballSchool.Pages.ScheduleModel
@{
    ViewData["Title"] = "Расписание тренировок";

    var daysOfWeek = new[] {
        DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday,
        DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday
    };

    var safeCurrentDate = Model.CurrentDate ?? DateTime.Today;
    var safeStartOfWeek = Model.StartOfWeek != default ? Model.StartOfWeek : safeCurrentDate.AddDays(-1 * ((7 + (safeCurrentDate.DayOfWeek - DayOfWeek.Monday)) % 7));
    var safeEndOfWeek = Model.EndOfWeek != default ? Model.EndOfWeek : safeStartOfWeek.AddDays(6);

    var currentWeekTrainings = Model.Trainings?
        .Where(t =>
        {
            var dt = t.DateTraining.ToDateTime(TimeOnly.MinValue);
            return dt >= safeStartOfWeek && dt <= safeEndOfWeek;
        })
        .GroupBy(t => t.DateTraining.DayOfWeek)
        .ToDictionary(g => g.Key, g => g.ToList()) ?? new Dictionary<DayOfWeek, List<FootballSchool.Models.Training>>();

    var currentDayTrainings = Model.Trainings?
        .Where(t => t.DateTraining == DateOnly.FromDateTime(safeCurrentDate))
        .OrderBy(t => t.TimeTraining)
        .ToList() ?? new List<FootballSchool.Models.Training>();

    var uniqueCoaches = Model.Trainings?
        .Where(t => t.Coach != null)
        .Select(t => t.Coach)
        .GroupBy(c => c.CoachId)
        .Select(g => g.First())
        .ToList() ?? new List<FootballSchool.Models.Coach>();
}

@functions {
    public string GetEventColorClass(int id)
    {
        var colors = new[] { "border-blue", "border-green", "border-orange", "border-purple", "border-red" };
        return colors[id % colors.Length];
    }
    public string GetLegendDot(int id)
    {
        var colors = new[] { "bg-blue", "bg-green", "bg-orange", "bg-purple", "bg-red" };
        return colors[id % colors.Length];
    }
}

@section Styles {
