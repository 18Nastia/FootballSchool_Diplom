@page
@model FootballSchool.Pages.ResetPasswordModel
@{
    ViewData["Title"] = "Создание нового пароля";
    Layout = null; // Отключаем боковое меню для страницы сброса
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Сброс пароля - FootballSchool</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    @section Styles {
        <link rel="stylesheet" href="~/css/reset-password.css" asp-append-version="true" />
    }
</head>
<body>
    <div class="reset-card">
        <h2 class="reset-title">Новый пароль</h2>

        @if (Model.IsSuccess)
        {
            <div class="alert alert-success text-center">
                Пароль успешно изменен!<br /><br />
                <a href="/Login" class="btn btn-primary w-100">Вернуться ко входу</a>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <form method="post">
                <input type="hidden" asp-for="Token" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Новый пароль</label>
                    <input type="password" asp-for="NewPassword" class="form-control" placeholder="Введите новый пароль" required />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Повторите пароль</label>
                    <input type="password" asp-for="ConfirmPassword" class="form-control" placeholder="Подтвердите новый пароль" required />
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">Сохранить пароль</button>
            </form>
        }
    </div>
</body>
</html>