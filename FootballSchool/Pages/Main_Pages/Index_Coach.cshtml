@page
@model FootballSchool.Pages.Main_Pages.Index_CoachModel
@{
    ViewData["Title"] = "Панель тренера";
}

@section Styles {
    <link rel="stylesheet" href="~/css/index-coach.css" asp-append-version="true" />
}


<div class="coach-page">
    <div class="coach-content">
        <!-- Welcome Section -->
        <div class="welcome-card">
            <h1 class="welcome-title">Добрый день, @(Model.CurrentCoach?.NameCoach ?? "Тренер")!</h1>
            <p class="welcome-subtitle">Сегодня у вас @Model.TodayTrainingsCount тренировок.</p>
        </div>

        <!-- Quick Actions -->
        <div class="quick-actions">
            <a href="/Attendance" class="action-card">
                <i class="fas fa-calendar-check action-icon"></i>
                <div class="action-title">Посещаемость</div>
                <div class="action-desc">Отметить присутствующих</div>
            </a>

            <a href="/TrainingResults" class="action-card">
                <i class="fas fa-chart-line action-icon"></i>
                <div class="action-title">Результаты</div>
                <div class="action-desc">Внести показатели</div>
            </a>

            <a href="/Schedule" class="action-card">
                <i class="fas fa-calendar-alt action-icon"></i>
                <div class="action-title">Мое расписание</div>
                <div class="action-desc">Просмотр всех занятий</div>
            </a>
        </div>

        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px;">
            <!-- Trainings Card -->
            <div class="trainings-card" style="margin-bottom: 0;">
                <h2 class="section-title">Ближайшие тренировки</h2>

                @if (!Model.UpcomingTrainings.Any())
                {
                    <p class="text-muted">На ближайшее время тренировок не запланировано.</p>
                }
                else
                {
                    <table class="trainings-table">
                        <thead>
                            <tr>
                                <th>Дата и Время</th>
                                <th>Группа</th>
                                <th>Место</th>
                                <th>План</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var training in Model.UpcomingTrainings)
                            {
                                <tr>
                                    <td>
                                        <div style="font-weight: 500;">@training.DateTraining.ToString("dd.MM.yyyy")</div>
                                        <div style="color: #6e6e73; font-size: 13px;">@training.TimeTraining.ToString("HH:mm")</div>
                                    </td>
                                    <td>
                                        <div style="font-weight: 500;">@(training.Team?.CategoryTeam ?? "Без группы")</div>
                                        <div style="color: #6e6e73; font-size: 13px;">@(training.Team?.Students.Count ?? 0) чел.</div>
                                    </td>
                                    <td>@(training.Facility?.NameFacility ?? "Не указано")</td>
                                    <td>@(string.IsNullOrEmpty(training.PlanTraining) ? "—" : training.PlanTraining)</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <a href="/Attendance" class="btn-primary">
                        <i class="fas fa-calendar-check"></i>
                        Открыть журнал посещаемости
                    </a>
                }
            </div>

            <!-- Statistics Card -->
            <div class="statistics-card" style="margin-bottom: 0;">
                <h2 class="section-title">Ваша статистика</h2>

                <div class="stat-row">
                    <span class="stat-label">Учеников в ваших группах</span>
                    <span class="stat-value">@Model.TotalStudents</span>
                </div>

                <div class="stat-row">
                    <span class="stat-label">Средняя посещаемость</span>
                    <span class="stat-value positive">@Model.AverageAttendance</span>
                </div>

                <div class="stat-row">
                    <span class="stat-label">Ближайшее занятие</span>
                    <span class="stat-value">
                        @(Model.UpcomingTrainings.FirstOrDefault()?.DateTraining.ToString("dd.MM") ?? "Нет данных")
                    </span>
                </div>
            </div>
        </div>

        <!-- News Card -->
        <div class="news-card mt-4">
            <h2 class="section-title">Новости и события</h2>

            <div class="news-items">
                <div class="news-item">
                    <div class="news-icon">
                        <i class="fas fa-clock"></i>
                    </div>
                    <span class="news-text">Напоминание: Не забывайте отмечать посещаемость после каждой тренировки.</span>
                </div>

                <div class="news-item">
                    <div class="news-icon trophy">
                        <i class="fas fa-trophy"></i>
                    </div>
                    <span class="news-text">Открыт функционал внесения результатов тестирования скорости и техники.</span>
                </div>
            </div>
        </div>
    </div>
</div> 