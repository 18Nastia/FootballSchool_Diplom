@page
@model FootballSchool.Pages.Main_Pages.Index_ParentModel
@{
    ViewData["Title"] = "Личный кабинет родителя";
}

@section Styles {
    <link rel="stylesheet" href="~/css/index-parent.css" asp-append-version="true" />
}

<div class="parent-page">
    <div class="parent-content">
        @if (Model.StudentData == null)
        {
            <div class="welcome-card empty-state">
                <i class="fas fa-user-clock fa-3x mb-3"></i>
                <h2>Данные не найдены</h2>
                <p>К вашему аккаунту еще не привязан профиль ученика.</p>
            </div>
        }
        else
        {
            <div class="welcome-card">
                <h1 class="welcome-title">Здравствуйте, @Model.StudentData.NameParent!</h1>
                <p class="welcome-text">Добро пожаловать в личный кабинет футбольной школы.</p>
            </div>

            <div class="content-grid">
                <div class="card profile-card">
                    <h2 class="card-title">Профиль ребёнка</h2>
                    <div class="profile-content">
                        @{
                            var photoPath = !string.IsNullOrEmpty(Model.StudentData.PhotoStudent)
                                ? "/uploads/" + Model.StudentData.PhotoStudent
                                : "https://via.placeholder.com/120?text=Спортсмен";
                        }
                        <img src="@photoPath" alt="@Model.StudentData.NameStudent" class="profile-photo">

                        <h3 class="profile-name">@Model.StudentData.NameStudent @Model.StudentData.SurnameStudent</h3>
                        <p class="profile-info">Группа: @(Model.StudentData.Team?.CategoryTeam ?? "Не назначена")</p>

                        <a asp-page="/ChildProfile" asp-route-id="@Model.StudentData.StudentId" class="btn-primary">
                            <i class="fas fa-child"></i>
                            Подробный профиль
                        </a>
                    </div>
                </div>

                <div class="card training-card">
                    <h2 class="card-title">Ближайшие тренировки</h2>
                    @if (Model.UpcomingTrainings != null && Model.UpcomingTrainings.Any())
                    {
                        <table class="training-table">
                            <thead>
                                <tr>
                                    <th>Дата</th>
                                    <th>Время</th>
                                    <th>Место</th>
                                    <th>Тренер</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var training in Model.UpcomingTrainings)
                                {
                                    <tr>
                                        <td>@training.DateTraining.ToString("dd.MM.yyyy")</td>
                                        <td>@training.TimeTraining.ToString("HH:mm")</td>
                                        <td>@(training.Facility?.NameFacility ?? "Площадка")</td>
                                        <td>@(training.Coach?.SurnameCoach ?? "Тренер")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="empty-state">Нет данных о тренировках</p>
                    }
                </div>
            </div>

            <div class="bottom-grid">
                <div class="card subscription-card">
                    <h2 class="card-title">Абонемент и оплата</h2>
                    <div class="subscription-content">
                        @if (Model.ActiveSubscription != null)
                        {
                            <div class="subscription-row">
                                <span class="subscription-label">Тип:</span>
                                <div class="subscription-value">
                                    <span class="subscription-name">@Model.ActiveSubscription.TypeSubscription</span>
                                    <span class="subscription-status">✓</span>
                                </div>
                            </div>
                            <div class="subscription-row">
                                <span class="subscription-label">Стоимость:</span>
                                <span class="subscription-date">@(Model.ActiveSubscription.CostSubscription?.ToString("N0") ?? "0") ₽</span>
                            </div>
                            <div class="subscription-row">
                                <span class="subscription-label">Длительность:</span>
                                <span class="subscription-date">@Model.ActiveSubscription.DaysSubscription дней</span>
                            </div>
                        }
                        else
                        {
                            <p class="text-danger">Нет активного абонемента</p>
                        }

                        <button class="btn-primary">
                            <i class="fas fa-credit-card"></i>
                            История платежей
                        </button>
                    </div>
                </div>

                <div class="card notifications-card">
                    <h2 class="card-title">Уведомления</h2>
                    <div class="notifications-content">
                        <div class="notification-item">
                            <i class="fas fa-info-circle"></i>
                            <span style="margin-left: 10px;">Следите за расписанием в соответствующем разделе меню.</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>