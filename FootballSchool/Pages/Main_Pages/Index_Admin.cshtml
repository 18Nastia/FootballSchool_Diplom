@page
@model FootballSchool.Pages.Main_Pages.Index_AdminModel
@{
    ViewData["Title"] = "Панель администратора";
}

@section Styles {
    <link rel="stylesheet" href="~/css/index-admin.css" asp-append-version="true" />
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success m-3"><i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger m-3"><i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]</div>
}

<div class="welcome-section">
    <h1 class="welcome-title">Добро пожаловать, <span id="secretTrigger" style="cursor: text; user-select: none;" title=":)">Администратор</span>!</h1>
    <p class="welcome-subtitle">
        Сегодня: <strong>@Model.TodayTrainingsCount</strong> тренировок,
        всего в школе: <strong>@Model.TotalStudentsCount</strong> учеников.
    </p>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-border blue"></div>
        <div class="stat-label">Посещаемость за неделю</div>
        <div class="stat-value">@Model.WeeklyAttendancePercentage%</div>
    </div>

    <div class="stat-card">
        <div class="stat-border green"></div>
        <div class="stat-label">Активные абонементы</div>
        <div class="stat-value">@Model.ActiveSubscriptionsCount</div>
    </div>

    <div class="stat-card">
        <div class="stat-border orange"></div>
        <div class="stat-label">Проблемные платежи</div>
        <div class="stat-value">@Model.PendingPaymentsCount</div>
    </div>

    <div class="stat-card">
        <div class="stat-border purple"></div>
        <div class="stat-label">Кол-во тренеров</div>
        <div class="stat-value">@Model.CoachesCount</div>
    </div>
</div>

<div class="content-grid">
    <div class="notifications-section">
        <div class="section-header">
            <h2 class="section-title" style="margin-bottom: 0;">Уведомления и события</h2>
            <a href="/Schedule" class="view-all-link">Перейти к расписанию</a>
        </div>

        <div class="notification-list">
            @foreach (var notification in Model.Notifications)
            {
                <div class="notification-item">
                    <div class="notification-text">@notification</div>
                </div>
            }
        </div>
    </div>

    <div class="quick-actions-section">
        <h2 class="section-title">Быстрые действия</h2>

        <div class="action-list">
            <a href="/TrainingResults" class="action-item">
                <i class="fas fa-file-alt action-icon"></i>
                <span>Отчеты и успеваемость</span>
            </a>

            <a href="/GroupsStudents" class="action-item">
                <i class="fas fa-users action-icon"></i>
                <span>Управление учениками</span>
            </a>

            <a href="/Schedule" class="action-item">
                <i class="fas fa-calendar-plus action-icon"></i>
                <span>Обновить расписание</span>
            </a>

            <a href="/Subscriptions" class="action-item">
                <i class="fas fa-credit-card action-icon"></i>
                <span>Управление оплатами</span>
            </a>
        </div>
    </div>
</div>

<!-- Скрытое модальное окно для добавления администратора -->
<div class="modal fade" id="addAdminModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="AddAdmin">
                <div class="modal-header">
                    <h5 class="modal-title">Регистрация администратора</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Логин <span class="text-danger">*</span></label>
                        <input type="text" name="adminLogin" class="form-control" required autocomplete="off" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Пароль <span class="text-danger">*</span></label>
                        <input type="text" name="adminPassword" class="form-control" required autocomplete="off" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="adminEmail" class="form-control" autocomplete="off" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary" style="background:#2563EB; border:none;">Зарегистрировать</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Скрытный триггер: двойной клик по слову "Администратор"
        document.getElementById('secretTrigger').addEventListener('dblclick', function () {
            if (typeof bootstrap !== 'undefined') {
                var myModal = new bootstrap.Modal(document.getElementById('addAdminModal'));
                myModal.show();
            } else {
                console.error("Bootstrap JS не загружен, невозможно открыть окно.");
            }
        });
    </script>
}