@page "{id:int?}"
@model FootballSchool.Pages.ChildProfileModel
@{
    ViewData["Title"] = "Профиль ребенка";
}

@section Styles {
    <link rel="stylesheet" href="~/css/child-profile.css" asp-append-version="true" />
}

<div class="profile-content">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success mt-3"><i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]</div>
    }

    <div class="profile-card">
        @if (User.IsInRole("Admin"))
        {
            <div class="admin-actions">
                <button class="btn-edit" data-bs-toggle="modal" data-bs-target="#editStudentModal">
                    <i class="fas fa-edit"></i> Редактировать
                </button>
                <form method="post" asp-page-handler="Delete" asp-route-id="@Model.StudentProfile?.StudentId" onsubmit="return confirm('Удалить профиль ученика безвозвратно?');">
                    <button type="submit" class="btn-delete">
                        <i class="fas fa-trash"></i> Удалить
                    </button>
                </form>
            </div>
        }

        @if (Model.StudentProfile != null)
        {
            <div class="profile-avatar">
                @if (!string.IsNullOrEmpty(Model.StudentProfile.PhotoPath))
                {
                    <img src="@Model.StudentProfile.PhotoPath"
                         class="avatar-circle"
                         alt="@Model.StudentProfile.FullName"
                         style="cursor: pointer;"
                         onclick="previewImage(this.src)"
                         onerror="this.onerror=null;this.src='/img/default-avatar.png'; this.parentElement.innerHTML='<div class=\'avatar-circle\'>@Model.StudentProfile.Initials</div><span class=\'status-badge\'>Активный</span>';">
                }
                else
                {
                    <div class="avatar-circle">@Model.StudentProfile.Initials</div>
                }
                <span class="status-badge">Активный</span>
            </div>

            <div class="profile-info">
                <h2 class="profile-name">@Model.StudentProfile.FullName</h2>

                <div class="info-grid">
                    <div class="info-item">
                        <i class="fas fa-user"></i>
                        <div>
                            <div class="info-label">Возраст / Уровень</div>
                            <div class="info-value">@Model.StudentProfile.Age лет (@Model.StudentProfile.Level)</div>
                        </div>
                    </div>

                    <div class="info-item">
                        <i class="fas fa-users"></i>
                        <div>
                            <div class="info-label">Группа</div>
                            <div class="info-value">@Model.StudentProfile.TeamName</div>
                        </div>
                    </div>

                    <div class="info-item">
                        <i class="fas fa-user-tie"></i>
                        <div>
                            <div class="info-label">Тренер</div>
                            <div class="info-value">@Model.StudentProfile.CoachName</div>
                        </div>
                    </div>

                    <div class="info-item">
                        <i class="fas fa-user-friends"></i>
                        <div>
                            <div class="info-label">Родитель</div>
                            <div class="info-value">@Model.StudentProfile.ParentName</div>
                        </div>
                    </div>

                    <div class="info-item">
                        <i class="fas fa-phone"></i>
                        <div>
                            <div class="info-label">Связь</div>
                            <div class="info-value">@Model.StudentProfile.ParentPhone</div>
                        </div>
                    </div>

                    <div class="info-item">
                        <i class="fas fa-map-marker-alt"></i>
                        <div>
                            <div class="info-label">Адрес</div>
                            <div class="info-value">@Model.StudentProfile.Address</div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted w-100">
                <h5>Ученик не найден</h5>
                <p>Пожалуйста, выберите ученика из общего списка.</p>
                <a href="/GroupsStudents" class="btn btn-primary mt-3">Вернуться к списку</a>
            </div>
        }
    </div>

    @if (Model.StudentProfile != null)
    {
        <div class="tabs">
            <button class="tab-btn active" data-tab="schedule"><i class="fas fa-calendar-alt"></i> Расписание</button>
            <button class="tab-btn" data-tab="results"><i class="fas fa-chart-line"></i> Результаты тестирования</button>
            <button class="tab-btn" data-tab="achievements"><i class="fas fa-medal"></i> Достижения</button>
        </div>

        <div class="content-sections">
            <section class="schedule-section active" id="schedule-section">
                <h3>Ближайшие тренировки группы «@Model.StudentProfile.TeamName»</h3>
                @if (Model.StudentProfile.Schedule.Any())
                {
                    <div class="schedule-grid">
                        @foreach (var session in Model.StudentProfile.Schedule)
                        {
                            <div class="schedule-card">
                                <div class="schedule-card-icon">
                                    <i class="far fa-calendar-check"></i>
                                </div>
                                <div class="schedule-details">
                                    <span class="s-date">@session.Date</span>
                                    <h4>@session.DayOfWeek</h4>
                                    <p>@session.Time | @session.Location</p>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">Для данной группы будущих тренировок пока не запланировано.</p>
                }
            </section>

            <section class="results-section" id="results-section">
                <h3>Динамика и результаты нормативов</h3>
                @if (Model.StudentProfile.Results.Any())
                {
                    <div class="results-list">
                        @foreach (var result in Model.StudentProfile.Results)
                        {
                            <div class="result-item">
                                <div class="result-info">
                                    <h4>@result.MetricName</h4>
                                    <p><i class="far fa-clock"></i> @result.Date | @result.Comment</p>
                                </div>
                                <div class="result-score">@result.Score</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">Результаты нормативов и тестов пока не добавлены тренером.</p>
                }
            </section>

            <section class="achievements-section" id="achievements-section">
                <div class="section-header-inline">
                    <h3 class="section-title-no-border">Личные достижения</h3>

                    @if (User.IsInRole("Admin"))
                    {
                        <button class="btn btn-primary btn-sm add-achievement-btn"
                                data-bs-toggle="modal"
                                data-bs-target="#addAchievementModal">
                            <i class="fas fa-plus me-1"></i> Добавить достижение
                        </button>
                    }
                </div>

                @if (Model.StudentProfile.Achievements.Any())
                {
                    <div class="achievements-grid">
                        @foreach (var ach in Model.StudentProfile.Achievements)
                        {
                            <div class="achievement-card">
                                @if (!string.IsNullOrEmpty(ach.PhotoPath))
                                {
                                    <img src="@ach.PhotoPath"
                                         alt="@ach.Title"
                                         class="achievement-photo"
                                         onclick="previewImage(this.src)" />

                                    <div class="achievement-body with-photo">
                                        <h4>@ach.Title</h4>
                                        <p>@ach.Description</p>
                                        <div class="achievement-date">
                                            <i class="far fa-calendar-alt me-1"></i> @ach.Date
                                        </div>

                                        @if (User.IsInRole("Admin") && ach.IsManual)
                                        {
                                            <form method="post"
                                                  asp-page-handler="DeleteProgress"
                                                  asp-route-progressId="@ach.Id"
                                                  asp-route-studentId="@Model.StudentProfile.StudentId"
                                                  onsubmit="return confirm('Вы уверены, что хотите удалить это достижение?');"
                                                  class="mt-3">
                                                <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                                                    <i class="fas fa-trash"></i> Удалить
                                                </button>
                                            </form>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="achievement-body no-photo">
                                        <div class="achievement-icon-wrapper">
                                            <i class="@ach.IconClass"></i>
                                        </div>
                                        <h4>@ach.Title</h4>
                                        <p>@ach.Description</p>
                                        <div class="achievement-date">
                                            <i class="far fa-calendar-alt me-1"></i> @ach.Date
                                        </div>

                                        @if (User.IsInRole("Admin") && ach.IsManual)
                                        {
                                            <form method="post"
                                                  asp-page-handler="DeleteProgress"
                                                  asp-route-progressId="@ach.Id"
                                                  asp-route-studentId="@Model.StudentProfile.StudentId"
                                                  onsubmit="return confirm('Вы уверены, что хотите удалить это достижение?');"
                                                  class="mt-3 w-100">
                                                <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                                                    <i class="fas fa-trash"></i> Удалить
                                                </button>
                                            </form>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">Здесь будут отображаться полученные достижения, сданные нормативы и медали.</p>
                }
            </section>
        </div>
    }
</div>

@if (Model.StudentProfile != null)
{
    @if (User.IsInRole("Admin"))
    {
        <div class="modal fade" id="addAchievementModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form method="post" asp-page-handler="AddAchievement" enctype="multipart/form-data">
                        <input type="hidden" name="studentId" value="@Model.StudentProfile.StudentId" />

                        <div class="modal-header">
                            <h5 class="modal-title">Новое достижение</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>

                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label">Заголовок (Событие)</label>
                                <input asp-for="NewAchievement.Title" class="form-control" placeholder="Например: Победитель летнего кубка" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Дата получения</label>
                                <input asp-for="NewAchievement.Date" type="date" class="form-control" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Описание</label>
                                <textarea asp-for="NewAchievement.Description" class="form-control" rows="3" placeholder="Краткое описание за что получена награда..." required></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Фотография (Медаль, Грамота, Кубок)</label>
                                <input type="file" name="AchievementPhoto" class="form-control" accept="image/*" />
                                <small class="text-muted">Загрузите фотографию для подтверждения. Это не обязательно.</small>
                            </div>
                        </div>

                        <div class="modal-footer">
                            <button type="submit" class="btn btn-primary w-100 modal-save-btn">Сохранить достижение</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }

    <div class="modal fade" id="editStudentModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <form method="post" asp-page-handler="Edit" enctype="multipart/form-data">
                    <div class="modal-header">
                        <h5 class="modal-title">Редактирование ученика</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        <input type="hidden" asp-for="EditStudent.StudentId" />
                        <input type="hidden" asp-for="EditStudent.PhotoStudent" />

                        <h6 class="mb-3 text-primary border-bottom pb-2">Фотография</h6>
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label>Текущее фото</label>
                                <div style="display:flex; align-items:center; gap:16px; flex-wrap:wrap;">
                                    @if (!string.IsNullOrEmpty(Model.EditStudent.PhotoStudent))
                                    {
                                        <img src="@Model.EditStudent.PhotoStudent"
                                             alt="Фото ученика"
                                             style="width:90px; height:90px; object-fit:cover; border-radius:50%; border:1px solid #e5e7eb;" />
                                    }
                                    else
                                    {
                                        <div style="width:90px; height:90px; border-radius:50%; background:#e5e7eb; display:flex; align-items:center; justify-content:center; font-weight:700; color:#2563eb;">
                                            @Model.StudentProfile.Initials
                                        </div>
                                    }

                                    <div style="flex:1; min-width:220px;">
                                        <label class="form-label">Новое фото</label>
                                        <input type="file" name="StudentPhoto" class="form-control" accept="image/*" />
                                        <small class="text-muted">Если файл не выбран, текущее фото останется прежним.</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <h6 class="mb-3 text-primary border-bottom pb-2">Основные данные</h6>
                        <div class="row">
                            <div class="col-md-4 mb-3"><label>Фамилия</label><input asp-for="EditStudent.SurnameStudent" class="form-control" required /></div>
                            <div class="col-md-4 mb-3"><label>Имя</label><input asp-for="EditStudent.NameStudent" class="form-control" required /></div>
                            <div class="col-md-4 mb-3"><label>Отчество</label><input asp-for="EditStudent.MiddleStudent" class="form-control" /></div>

                            <div class="col-md-4 mb-3"><label>Дата рождения</label><input asp-for="EditStudent.BirthStudent" type="date" class="form-control" required /></div>
                            <div class="col-md-4 mb-3">
                                <label>Пол</label>
                                <select asp-for="EditStudent.GenderStudent" class="form-select" required>
                                    <option value="Мужской">Мужской</option>
                                    <option value="Женский">Женский</option>
                                </select>
                            </div>
                            <div class="col-md-4 mb-3"><label>Уровень</label><input asp-for="EditStudent.LevelStudent" class="form-control" required /></div>

                            <div class="col-md-12 mb-3">
                                <label>Группа</label>
                                <select asp-for="EditStudent.TeamId" asp-items="Model.TeamList" class="form-select">
                                    <option value="">Выберите группу...</option>
                                </select>
                            </div>
                            <div class="col-md-12 mb-3"><label>Мед. показания</label><textarea asp-for="EditStudent.MedicalStudent" class="form-control" rows="2"></textarea></div>
                        </div>

                        <h6 class="mb-3 mt-3 text-primary border-bottom pb-2">Данные родителя</h6>
                        <div class="row">
                            <div class="col-md-4 mb-3"><label>Фамилия</label><input asp-for="EditStudent.SurnameParent" class="form-control" required /></div>
                            <div class="col-md-4 mb-3"><label>Имя</label><input asp-for="EditStudent.NameParent" class="form-control" required /></div>
                            <div class="col-md-4 mb-3"><label>Отчество</label><input asp-for="EditStudent.MiddleParent" class="form-control" /></div>
                            <div class="col-md-12 mb-3"><label>Телефон родителя</label><input asp-for="EditStudent.ParentNumber" class="form-control" required /></div>
                        </div>

                        <h6 class="mb-3 mt-3 text-primary border-bottom pb-2">Адрес</h6>
                        <div class="row">
                            <div class="col-md-6 mb-3"><label>Город</label><input asp-for="EditStudent.CityStudent" class="form-control" required /></div>
                            <div class="col-md-6 mb-3"><label>Улица</label><input asp-for="EditStudent.StreetStudent" class="form-control" required /></div>
                            <div class="col-md-6 mb-3"><label>Дом</label><input asp-for="EditStudent.HouseStudent" class="form-control" required /></div>
                            <div class="col-md-6 mb-3"><label>Квартира</label><input asp-for="EditStudent.ApartmentStudent" class="form-control" /></div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary modal-save-btn">Сохранить изменения</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="imagePreviewModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content bg-transparent border-0">
                <div class="modal-header border-0 p-0 justify-content-end mb-2">
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Close"
                            style="background-color: white; border-radius: 50%; opacity: 0.8; padding: 10px;"></button>
                </div>
                <div class="modal-body text-center p-0">
                    <img id="fullSizeImage"
                         src=""
                         alt="Preview"
                         style="max-width: 100%; max-height: 85vh; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.5);" />
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');

                document.querySelectorAll('.schedule-section, .results-section, .achievements-section').forEach(section => {
                    section.classList.remove('active');
                });

                const tabName = this.getAttribute('data-tab');
                const targetSection = document.getElementById(tabName + '-section');
                if (targetSection) {
                    targetSection.classList.add('active');
                }
            });
        });

        function previewImage(src) {
            if (!src) return;
            document.getElementById('fullSizeImage').src = src;
            var previewModal = new bootstrap.Modal(document.getElementById('imagePreviewModal'));
            previewModal.show();
        }
    </script>
}