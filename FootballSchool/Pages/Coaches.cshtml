@page
@model FootballSchool.Pages.CoachesModel
@{
    ViewData["Title"] = "Список тренеров";
}

@section Styles {
    <link rel="stylesheet" href="~/css/coaches.css" asp-append-version="true" />
}

<div class="coaches-container">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success m-3"><i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger m-3"><i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]</div>
    }

    <div class="page-top-header">
        <h1>Тренерский состав</h1>

        @if (User.IsInRole("Admin"))
        {
            <button class="btn-add" data-bs-toggle="modal" data-bs-target="#addCoachModal">
                <i class="fas fa-plus"></i> Добавить тренера
            </button>
        }
    </div>

    <div class="coaches-content">
        <div class="filters-panel">
            <div class="filter-section">
                <h4>Специализация</h4>
                <div class="filter-option">
                    <input type="radio" id="spec-all" name="specialization" value="all" checked>
                    <label for="spec-all">Все специализации</label>
                </div>
                @foreach (var spec in Model.Specialties)
                {
                    var safeSpecId = spec.Replace(" ", "-").Replace("/", "-").Replace("\\", "-").ToLower();
                    <div class="filter-option">
                        <input type="radio" id="spec-@safeSpecId" name="specialization" value="@spec.ToLower()">
                        <label for="spec-@safeSpecId">@spec</label>
                    </div>
                }
            </div>

            <div class="filter-section">
                <h4>Занятость</h4>
                <div class="filter-option">
                    <input type="radio" id="status-all" name="status" value="all" checked>
                    <label for="status-all">Все</label>
                </div>
                <div class="filter-option">
                    <input type="radio" id="status-free" name="status" value="status-free">
                    <label for="status-free">Свободен</label>
                </div>
                <div class="filter-option">
                    <input type="radio" id="status-busy" name="status" value="status-busy">
                    <label for="status-busy">Ведет группы (Занят)</label>
                </div>
            </div>
        </div>

        <div class="trainers-list">
            @if (!Model.CoachesList.Any())
            {
                <div class="text-muted">Тренеры не найдены.</div>
            }
            else
            {
                @foreach (var coach in Model.CoachesList)
                {
                    <div class="trainer-card"
                         data-specialty="@coach.Specialty.ToLower()"
                         data-status="@coach.StatusClass">

                        @if (User.IsInRole("Admin"))
                        {
                            <div class="trainer-card-actions">
                                <a href="/CoachProfile/@coach.CoachId"
                                   class="btn btn-sm btn-light"
                                   title="Открыть профиль"
                                   onclick="event.stopPropagation();">
                                    <i class="fas fa-eye"></i>
                                </a>

                                <form method="post"
                                      asp-page-handler="DeleteCoach"
                                      asp-route-id="@coach.CoachId"
                                      onsubmit="event.stopPropagation(); return confirm('Удалить тренера? Все его тренировки и посещения по ним будут удалены.');">
                                    <button type="submit"
                                            class="btn btn-sm btn-delete-coach"
                                            title="Удалить тренера">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        }

                        <a href="/CoachProfile/@coach.CoachId" class="trainer-link">
                            @if (!string.IsNullOrEmpty(coach.PhotoPath))
                            {
                                <img src="@coach.PhotoPath"
                                     class="trainer-avatar"
                                     alt="@coach.FullName"
                                     onerror="this.onerror=null; this.outerHTML='<div class=&quot;trainer-avatar&quot;>@coach.Initials</div>';" />
                            }
                            else
                            {
                                <div class="trainer-avatar">@coach.Initials</div>
                            }

                            <div class="trainer-info">
                                <div class="trainer-name">@coach.FullName</div>
                                <div class="trainer-spec">@coach.Specialty</div>
                                <div class="trainer-meta">
                                    <span class="status-badge @coach.StatusClass">@coach.StatusText</span>
                                    <span class="trainer-qualification">@coach.Qualification</span>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            }
        </div>
    </div>
</div>

@if (User.IsInRole("Admin"))
{
    <div class="modal fade" id="addCoachModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <form method="post" asp-page-handler="AddCoach" enctype="multipart/form-data">
                    <div class="modal-header">
                        <h5 class="modal-title">Регистрация нового тренера</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <h6 class="mb-3 text-primary border-bottom pb-2">Основные данные</h6>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label>Фамилия</label>
                                <input asp-for="NewCoach.SurnameCoach" class="form-control" required />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label>Имя</label>
                                <input asp-for="NewCoach.NameCoach" class="form-control" required />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label>Отчество</label>
                                <input asp-for="NewCoach.MiddleCoach" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label>Специализация</label>
                                <input asp-for="NewCoach.SpecialtyCoach" class="form-control" placeholder="Например: Силовые тренировки" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label>Квалификация</label>
                                <input asp-for="NewCoach.QualificationCoach" class="form-control" placeholder="Например: КМС, Высшее образование" required />
                            </div>
                            <div class="col-md-12 mb-3">
                                <label>Фотография тренера</label>
                                <input type="file" name="CoachPhotoUpload" class="form-control" accept="image/*" />
                            </div>
                        </div>

                        <h6 class="mb-3 mt-3 text-primary border-bottom pb-2">Условия работы</h6>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label>Ставка / Зарплата (₽)</label>
                                <input asp-for="NewCoach.SalaryCoach" type="number" step="0.01" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label>График работы</label>
                                <input asp-for="NewCoach.ScheduleCoach" class="form-control" placeholder="Пн, Ср, Пт 18:00-21:00" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary btn-save-coach">Зарегистрировать тренера</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.querySelectorAll('input[type="radio"]').forEach(radio => {
            radio.addEventListener('change', function () {
                const specVal = document.querySelector('input[name="specialization"]:checked').value;
                const statVal = document.querySelector('input[name="status"]:checked').value;

                document.querySelectorAll('.trainer-card').forEach(card => {
                    const cardSpec = card.getAttribute('data-specialty');
                    const cardStat = card.getAttribute('data-status');

                    const matchSpec = specVal === 'all' || cardSpec.includes(specVal);
                    const matchStat = statVal === 'all' || cardStat === statVal;

                    card.style.display = (matchSpec && matchStat) ? 'flex' : 'none';
                });
            });
        });
    </script>
}