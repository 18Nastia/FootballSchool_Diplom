@page
@model FootballSchool.Pages.PaymentsModel
@{
    ViewData["Title"] = "Реестр платежей";
}

@section Styles {
    <style>
        .payments-page .main-content {
            margin-left: 0 !important;
            background-color: #F9FAFB;
            min-height: 100vh;
        }

        .content-header {
            margin-bottom: 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .content-header h1 {
                font-size: 28px;
                font-weight: 600;
                color: #111827;
                margin: 0;
            }

        .btn-primary {
            background-color: #2563eb;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: 0.2s;
        }

            .btn-primary:hover {
                background-color: #1d4ed8;
            }

        .table-container {
            background: white;
            border-radius: 12px;
            border: 1px solid #E5E7EB;
            overflow: hidden;
        }

        .admin-table {
            width: 100%;
            border-collapse: collapse;
        }

            .admin-table th {
                background: #f9fafb;
                padding: 16px;
                text-align: left;
                font-size: 13px;
                color: #6b7280;
                font-weight: 600;
                text-transform: uppercase;
                border-bottom: 1px solid #E5E7EB;
            }

            .admin-table td {
                padding: 16px;
                border-bottom: 1px solid #f3f4f6;
                font-size: 14px;
                color: #111827;
                vertical-align: middle;
            }

            .admin-table tr:hover {
                background-color: #f9fafb;
            }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
        }

            .status-badge.success {
                background-color: #dcfce7;
                color: #15803d;
            }

            .status-badge.warning {
                background-color: #fef3c7;
                color: #92400e;
            }

            .status-badge.error {
                background-color: #fee2e2;
                color: #dc2626;
            }

        .action-btns {
            display: flex;
            gap: 8px;
        }

        .btn-icon {
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            padding: 6px 10px;
            color: #4b5563;
            cursor: pointer;
            transition: 0.2s;
        }

            .btn-icon:hover {
                background: #f3f4f6;
                color: #2563eb;
            }

            .btn-icon.delete:hover {
                color: #dc2626;
                border-color: #fecaca;
                background: #fef2f2;
            }
    </style>
}

<div class="payments-page">
    <div class="main-content">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success mb-3"><i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger mb-3"><i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]</div>
        }

        <div class="content-header">
            <h1>Бухгалтерия и платежи</h1>
            <button class="btn-primary" data-bs-toggle="modal" data-bs-target="#paymentModal" onclick="prepareAddPayment()">
                <i class="fas fa-plus"></i> Зарегистрировать платеж
            </button>
        </div>

        <div class="table-container">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Дата</th>
                        <th>Ученик</th>
                        <th>Основание (Абонемент)</th>
                        <th>Способ</th>
                        <th>Сумма</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.PaymentsList.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">Платежей пока нет.</td></tr>
                    }
                    @foreach (var p in Model.PaymentsList)
                    {
                        string badgeClass = p.Status == "Оплачен" ? "success" : (p.Status == "Ошибка" ? "error" : "warning");
                        string iconClass = p.Status == "Оплачен" ? "fa-check" : (p.Status == "Ошибка" ? "fa-times" : "fa-clock");

                        <tr>
                            <td>@p.Date.ToString("dd.MM.yyyy")</td>
                            <td><strong>@p.StudentName</strong></td>
                            <td class="text-muted">@p.SubscriptionInfo</td>
                            <td>@p.Method</td>
                            <td style="font-weight: 600;">@p.Amount.ToString("N0") ₽</td>
                            <td>
                                <span class="status-badge @badgeClass"><i class="fas @iconClass"></i> @p.Status</span>
                            </td>
                            <td>
                                <div class="action-btns">
                                    <button class="btn-icon" title="Изменить статус" onclick="prepareEditPayment(@p.PaymentId, '@p.Status', '@p.Method', @p.Amount.ToString(System.Globalization.CultureInfo.InvariantCulture))" data-bs-toggle="modal" data-bs-target="#paymentModal">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <form method="post" asp-page-handler="DeletePayment" asp-route-id="@p.PaymentId" onsubmit="return confirm('Вы уверены, что хотите удалить запись о платеже?');">
                                        <button type="submit" class="btn-icon delete" title="Удалить">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="SavePayment">
                <div class="modal-header">
                    <h5 class="modal-title" id="paymentModalTitle">Регистрация платежа</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="ModalPayment.PaymentId" id="payId" />

                    <div class="mb-3" id="subSelectDiv">
                        <label>Связанный абонемент</label>
                        <select asp-for="ModalPayment.SubscriptionId" asp-items="Model.SubscriptionsList" class="form-select" required>
                            <option value="">Выберите абонемент...</option>
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label>Сумма (₽)</label>
                            <input asp-for="ModalPayment.AmountPayment" id="payAmount" type="number" step="0.01" class="form-control" required />
                        </div>
                        <div class="col-6 mb-3">
                            <label>Дата оплаты</label>
                            <input asp-for="ModalPayment.DatePayment" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label>Способ оплаты</label>
                        <select asp-for="ModalPayment.MethodPayment" id="payMethod" class="form-select" required>
                            <option value="Наличные">Наличные</option>
                            <option value="Перевод на карту">Перевод на карту</option>
                            <option value="Онлайн-эквайринг">Онлайн-эквайринг</option>
                            <option value="Терминал">Терминал (эквайринг)</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label>Статус платежа</label>
                        <select asp-for="ModalPayment.StatusPayment" id="payStatus" class="form-select" required>
                            <option value="Оплачен">Оплачен</option>
                            <option value="В обработке">В обработке / Ожидает</option>
                            <option value="Ошибка">Ошибка оплаты</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary w-100 justify-content-center">Сохранить данные</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function prepareAddPayment() {
            document.getElementById('paymentModalTitle').innerText = 'Регистрация нового платежа';
            document.getElementById('payId').value = '0';
            document.getElementById('subSelectDiv').style.display = 'block';
            document.getElementById('payAmount').value = '';
            document.getElementById('payMethod').value = 'Наличные';
            document.getElementById('payStatus').value = 'Оплачен';
        }

        function prepareEditPayment(id, status, method, amount) {
            document.getElementById('paymentModalTitle').innerText = 'Изменение платежа';
            document.getElementById('payId').value = id;
            document.getElementById('subSelectDiv').style.display = 'none';
            document.getElementById('payAmount').value = amount;
            document.getElementById('payMethod').value = method;
            document.getElementById('payStatus').value = status;
        }
    </script>
}