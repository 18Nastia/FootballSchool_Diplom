@page
@model FootballSchool.Pages.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Вход - FootballSchool</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <div class="login-card">
        <div class="login-header">
            <i class="fas fa-futbol"></i>
            <h2>FootballSchool</h2>
            <p class="text-muted mt-2">Вход в личный кабинет</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.InfoMessage))
        {
            <div class="alert alert-info" role="alert">
                <i class="fas fa-info-circle me-2"></i> @Model.InfoMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i> @Model.ErrorMessage
            </div>
        }

        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-bold text-uppercase">Логин</label>
                <input asp-for="Login" class="form-control" placeholder="Введите ваш логин" required autofocus />
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold text-uppercase">Пароль</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Введите ваш пароль" required />
            </div>

            <button type="submit" class="btn btn-primary">
                Войти <i class="fas fa-arrow-right ms-2"></i>
            </button>
        </form>

        <div class="text-center mt-4">
            <small class="text-muted">Если вы забыли пароль, обратитесь к администратору.</small>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (localStorage.getItem('theme') === 'dark') {
                document.body.classList.add('dark-theme');
            }
        });
    </script>
</body>
</html>