@page
@model FootballSchool.Pages.BranchesModel
@{
    ViewData["Title"] = "Филиалы и площадки";
}

@functions {
    public string GetRandomImage(int id)
    {
        var images = new[]
        {
            "https://i.pinimg.com/736x/19/d9/13/19d913826d2c69f826db12aad83b5376.jpg",
            "https://img.freepik.com/premium-photo/aerial-view-of-mini-football-field_7258-107.jpg?w=2000",
            "https://images.satu.kz/59020015_w640_h640_montazh-iskusstvennogo-gazona.jpg",
            "https://static.mk.ru/upload/entities/2025/10/13/13/articles/facebookPicture/df/3a/98/39/df83f6eb48eab142815f7aa247e5a9f9.jpg",
            "https://avatars.mds.yandex.net/get-altay/4012648/2a00000178af1245f5a0dbbddc039f732cf7/orig"
        };
        return images[id % images.Length];
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/branches.css" asp-append-version="true" />
}

<div class="branches-page">
    <div class="overlay" id="overlay" onclick="closeBranchDetails()"></div>

    <div class="branches-content" id="mainContent">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success mb-4">
                <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger mb-4">
                <i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]
            </div>
        }

        <header class="header">
            <h1>Филиалы и площадки</h1>

            @if (User.IsInRole("Admin"))
            {
                <div class="header-actions">
                    <button class="btn-primary" data-bs-toggle="modal" data-bs-target="#branchModal" onclick="prepareAddBranchModal()">
                        <i class="fas fa-plus"></i>
                        <span>Добавить филиал</span>
                    </button>
                </div>
            }
        </header>

        <form method="get" class="filters w-100" id="filterForm">
            <div class="filter-group">
                <label>Город</label>
                <select asp-for="FilterCity" asp-items="Model.CityList" class="filter-select" onchange="this.form.submit()">
                    <option value="">Все города</option>
                </select>
            </div>

            <div class="filter-group">
                <label>Тип зала</label>
                <select asp-for="FilterType" asp-items="Model.TypeList" class="filter-select" onchange="this.form.submit()">
                    <option value="">Все типы</option>
                </select>
            </div>

            <div class="filter-group">
                <label>Статус площадки</label>
                <select asp-for="FilterStatus" asp-items="Model.StatusList" class="filter-select" onchange="this.form.submit()">
                    <option value="">Все статусы</option>
                </select>
            </div>
        </form>

        @if (!Model.Branches.Any())
        {
            <div class="alert alert-info">По вашему запросу филиалов не найдено.</div>
        }
        else
        {
            <div class="cards-grid">
                @foreach (var branch in Model.Branches)
                {
                    <div class="card" onclick="openBranchDetails(@branch.BranchId)">
                        <div class="card-image">
                            <img src="@(string.IsNullOrEmpty(branch.PhotoPath) ? GetRandomImage(branch.BranchId) : branch.PhotoPath)"
                                 onerror="this.onerror=null; this.src='@GetRandomImage(branch.BranchId)';"
                                 alt="Branch" />
                        </div>

                        <div class="card-content">
                            <h3 class="text-truncate" title="@branch.Name">@branch.Name</h3>

                            <div class="card-info">
                                <div class="info-item text-truncate">
                                    <i class="fas fa-map-marker-alt"></i>
                                    <span>@branch.Address · @branch.City</span>
                                </div>

                                <div class="info-item text-truncate">
                                    <i class="fas fa-user-tie"></i>
                                    <span>@branch.MainCoachName</span>
                                </div>

                                <div class="info-item">
                                    <i class="fas fa-layer-group"></i>
                                    <span>Площадок: @branch.Facilities.Count</span>
                                </div>

                                @if (User.IsInRole("Admin"))
                                {
                                    <form method="post"
                                          asp-page-handler="DeleteBranch"
                                          asp-route-id="@branch.BranchId"
                                          class="branch-delete-form"
                                          onsubmit="return confirm('Удалить филиал? Все связанные площадки, тренировки и другие зависимые данные тоже будут удалены.');"
                                          onclick="event.stopPropagation();">
                                        <button type="submit"
                                                class="quick-add-btn"
                                                title="Удалить филиал">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                }
                            </div>

                            <div class="card-footer">
                                <span class="details-link">
                                    Открыть профиль <i class="fas fa-arrow-right"></i>
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <aside class="right-sidebar" id="branchSidebar">
        <div class="sidebar-header">
            <h2>Профиль филиала</h2>
            <button class="close-btn" type="button" onclick="closeBranchDetails()">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div id="sidebarDynamicContent" class="d-flex flex-column h-100"></div>
    </aside>
</div>

<div id="sidebar-data-store" style="display: none;">
    @foreach (var branch in Model.Branches)
    {
        var safeName = branch.Name.Replace("'", "\\'");
        var safeCity = branch.City.Replace("'", "\\'");
        var safeStreet = branch.Street.Replace("'", "\\'");
        var safeHouse = branch.House.Replace("'", "\\'");
        var safePhone = branch.Phone?.Replace("'", "\\'") ?? "";

        <div id="branch-content-@branch.BranchId" class="d-flex flex-column h-100">
            <div class="sidebar-body">
                <div class="branch-preview">
                    <img src="@(string.IsNullOrEmpty(branch.PhotoPath) ? GetRandomImage(branch.BranchId) : branch.PhotoPath)"
                         onerror="this.onerror=null; this.src='@GetRandomImage(branch.BranchId)';"
                         alt="Branch preview" />
                </div>

                <div class="branch-details">
                    <h3>@branch.Name</h3>
                    <div class="info-item mb-2">
                        <i class="fas fa-map-marker-alt"></i>
                        <span>@branch.Address, @branch.City</span>
                    </div>
                    <div class="info-item mb-2">
                        <i class="fas fa-phone"></i>
                        <span>@(string.IsNullOrEmpty(branch.Phone) ? "Не указан" : branch.Phone)</span>
                    </div>
                </div>

                <div class="tabs">
                    <button type="button" class="tab active" onclick="switchSidebarTab(event, 'info-@branch.BranchId')">Площадки</button>
                    <button type="button" class="tab" onclick="switchSidebarTab(event, 'schedule-@branch.BranchId')">Расписание</button>
                    <button type="button" class="tab" onclick="switchSidebarTab(event, 'groups-@branch.BranchId')">Группы</button>
                </div>

                <div class="sidebar-tab-content active" id="info-@branch.BranchId">
                    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                        <h4 class="mb-0">Залы (@branch.Facilities.Count)</h4>

                        @if (User.IsInRole("Admin"))
                        {
                            <button class="btn btn-sm btn-outline-primary"
                                    data-bs-toggle="modal"
                                    data-bs-target="#facilityModal"
                                    onclick="prepareAddFacilityModal(@branch.BranchId)">
                                + Добавить
                            </button>
                        }
                    </div>

                    @foreach (var facility in branch.Facilities)
                    {
                        var statusClass = facility.StatusFacility == "Активен"
                        ? "active-status"
                        : facility.StatusFacility == "На ремонте"
                        ? "repair-status"
                        : "new-status";

                        <div class="hall-card">
                            <div class="d-flex justify-content-between mb-2 flex-wrap gap-2">
                                <strong>@facility.NameFacility</strong>
                                <span class="hall-status @statusClass">@facility.StatusFacility</span>
                            </div>

                            <div class="hall-info">
                                <span>Тип: @facility.TypeFacility</span>
                                <span>Вместимость: @facility.CapacityFacility чел.</span>
                                @if (!string.IsNullOrEmpty(facility.NumberFacility))
                                {
                                    <span>Телефон: @facility.NumberFacility</span>
                                }
                            </div>

                            @if (User.IsInRole("Admin"))
                            {
                                <div class="hall-actions">
                                    <button type="button"
                                            class="action-link"
                                            data-bs-toggle="modal"
                                            data-bs-target="#facilityModal"
                                            onclick="prepareEditFacilityModal(
                                                            @facility.FacilityId,
                                                            @branch.BranchId,
                                                            '@(facility.NameFacility?.Replace("'", "\\'") ?? "")',
                                                            '@facility.TypeFacility',
                                                            '@facility.CapacityFacility',
                                                            '@facility.StatusFacility',
                                                            '@(facility.CostFacility?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0")',
                                                            '@(facility.NumberFacility?.Replace("'", "\\'") ?? "")'
                                                        )">
                                        Изменить
                                    </button>

                                    <form method="post"
                                          asp-page-handler="DeleteFacility"
                                          asp-route-id="@facility.FacilityId"
                                          class="d-inline"
                                          onsubmit="return confirm('Удалить?');">
                                        <button type="submit" class="action-link delete">Удалить</button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="sidebar-tab-content" id="schedule-@branch.BranchId">
                    <h4 class="mb-3">Ближайшие тренировки</h4>

                    @foreach (var t in branch.UpcomingTrainings)
                    {
                        <div class="list-item-card" style="border-left-color: #10B981;">
                            <h6>@t.DateTraining.ToString("dd MMM") в @t.TimeTraining.ToString("HH:mm")</h6>
                            <p>@t.PlanTraining</p>
                        </div>
                    }
                </div>

                <div class="sidebar-tab-content" id="groups-@branch.BranchId">
                    <h4 class="mb-3">Группы филиала</h4>

                    @foreach (var t in branch.BranchTeams)
                    {
                        <div class="list-item-card" style="border-left-color: #8B5CF6;">
                            <h6>@t.CategoryTeam</h6>
                            <p>Статус: @t.StatusTeam</p>
                        </div>
                    }
                </div>
            </div>

            @if (User.IsInRole("Admin"))
            {
                <div class="sidebar-actions mt-auto">
                    <button type="button"
                            class="btn-edit"
                            data-bs-toggle="modal"
                            data-bs-target="#branchModal"
                            onclick="prepareEditBranchModal(@branch.BranchId, '@safeName', '@safeCity', '@safeStreet', '@safeHouse', '@safePhone')">
                        <i class="fas fa-edit"></i> Редактировать
                    </button>

                    <form method="post"
                          asp-page-handler="DeleteBranch"
                          asp-route-id="@branch.BranchId"
                          class="flex-grow-1"
                          onsubmit="return confirm('Удалить филиал?');">
                        <button type="submit" class="btn-delete w-100">
                            <i class="fas fa-trash"></i> Удалить
                        </button>
                    </form>
                </div>
            }
        </div>
    }
</div>

<div class="modal fade" id="branchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form method="post" asp-page-handler="SaveBranch" enctype="multipart/form-data">
                <div class="modal-header">
                    <h5 class="modal-title" id="branchModalTitle">Филиал</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" asp-for="ModalBranch.BranchId" id="ModalBranch_Id" />

                    <div class="mb-3">
                        <label class="form-label">Название <span class="text-danger">*</span></label>
                        <input asp-for="ModalBranch.NameBranch" class="form-control" required id="ModalBranch_Name" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Город <span class="text-danger">*</span></label>
                        <input asp-for="ModalBranch.CityBranch" class="form-control" required id="ModalBranch_City" />
                    </div>

                    <div class="row g-3">
                        <div class="col-8">
                            <label class="form-label">Улица <span class="text-danger">*</span></label>
                            <input asp-for="ModalBranch.StreetBranch" class="form-control" required id="ModalBranch_Street" />
                        </div>
                        <div class="col-4">
                            <label class="form-label">Дом <span class="text-danger">*</span></label>
                            <input asp-for="ModalBranch.HouseBranch" class="form-control" required id="ModalBranch_House" />
                        </div>
                    </div>

                    <div class="mt-3 mb-3">
                        <label class="form-label">Телефон <span class="text-danger">*</span></label>
                        <input asp-for="ModalBranch.PhoneBranch" class="form-control" required id="ModalBranch_Phone" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Фото</label>
                        <input type="file" name="BranchPhoto" id="BranchPhoto" class="form-control" accept="image/*" />
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary">Сохранить</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="facilityModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="SaveFacility">
                <div class="modal-header">
                    <h5>Площадка</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" asp-for="ModalFacility.FacilityId" id="ModalFacility_Id" />
                    <input type="hidden" asp-for="ModalFacility.BranchId" id="ModalFacility_BranchId" />

                    <div class="mb-3">
                        <label>Название <span class="text-danger">*</span></label>
                        <input asp-for="ModalFacility.NameFacility" class="form-control" required id="ModalFacility_Name" />
                    </div>

                    <div class="mb-3">
                        <label>Телефон площадки</label>
                        <input asp-for="ModalFacility.NumberFacility" class="form-control" id="ModalFacility_Num" placeholder="+7 (___) ___-__-__" />
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label>Тип <span class="text-danger">*</span></label>
                            <select asp-for="ModalFacility.TypeFacility" class="form-select" required id="ModalFacility_Type">
                                <option value="Футбольное поле">Поле</option>
                                <option value="Манеж">Манеж</option>
                                <option value="Тренажерный">Зал</option>
                            </select>
                        </div>

                        <div class="col-6 mb-3">
                            <label>Вместимость <span class="text-danger">*</span></label>
                            <input asp-for="ModalFacility.CapacityFacility" class="form-control" type="number" required min="1" id="ModalFacility_Cap" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label>Статус <span class="text-danger">*</span></label>
                            <select asp-for="ModalFacility.StatusFacility" class="form-select" required id="ModalFacility_Stat">
                                <option value="Активен">Активен</option>
                                <option value="На ремонте">На ремонте</option>
                            </select>
                        </div>

                        <div class="col-6 mb-3">
                            <label>Стоимость (₽) <span class="text-danger">*</span></label>
                            <input asp-for="ModalFacility.CostFacility" class="form-control" type="number" step="0.01" required min="0" id="ModalFacility_Cost" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Сохранить</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            setupModalReset('branchModal', resetBranchModal);
            setupModalReset('facilityModal', resetFacilityModal);
        });

        function openBranchDetails(id) {
            const sidebar = document.getElementById('branchSidebar');
            const content = document.getElementById('branch-content-' + id);

            document.getElementById('sidebarDynamicContent').innerHTML = content.innerHTML;
            sidebar.classList.add('active');
            document.getElementById('mainContent').classList.add('with-sidebar');
            document.getElementById('overlay').classList.add('active');
            document.body.classList.add('sidebar-open');
        }

        function closeBranchDetails() {
            document.getElementById('branchSidebar').classList.remove('active');
            document.getElementById('mainContent').classList.remove('with-sidebar');
            document.getElementById('overlay').classList.remove('active');
            document.body.classList.remove('sidebar-open');
        }

        function switchSidebarTab(event, tabId) {
            const parent = event.target.closest('#sidebarDynamicContent');
            if (!parent) return;

            parent.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            event.target.classList.add('active');

            parent.querySelectorAll('.sidebar-tab-content').forEach(c => c.classList.remove('active'));

            const target = parent.querySelector('#' + tabId);
            if (target) {
                target.classList.add('active');
            }
        }

        function prepareAddBranchModal() {
            resetBranchModal();
            document.querySelector('#branchModal h5').innerText = 'Новый филиал';
        }

        function prepareEditBranchModal(id, name, city, street, house, phone) {
            resetBranchModal();

            document.getElementById('ModalBranch_Id').value = id;
            document.getElementById('ModalBranch_Name').value = name;
            document.getElementById('ModalBranch_City').value = city;
            document.getElementById('ModalBranch_Street').value = street;
            document.getElementById('ModalBranch_House').value = house;
            document.getElementById('ModalBranch_Phone').value = phone;
            document.querySelector('#branchModal h5').innerText = 'Редактирование филиала';
        }

        function prepareAddFacilityModal(branchId) {
            resetFacilityModal();

            document.getElementById('ModalFacility_Id').value = 0;
            document.getElementById('ModalFacility_BranchId').value = branchId;
        }

        function prepareEditFacilityModal(id, branchId, name, type, cap, stat, cost, num) {
            resetFacilityModal();

            document.getElementById('ModalFacility_Id').value = id;
            document.getElementById('ModalFacility_BranchId').value = branchId;
            document.getElementById('ModalFacility_Name').value = name;
            document.getElementById('ModalFacility_Type').value = type;
            document.getElementById('ModalFacility_Cap').value = cap;
            document.getElementById('ModalFacility_Stat').value = stat;
            document.getElementById('ModalFacility_Cost').value = cost;

            var numField = document.getElementById('ModalFacility_Num');
            if (numField) numField.value = num;
        }

        function resetBranchModal() {
            const modal = document.getElementById('branchModal');
            if (!modal) return;

            const form = modal.querySelector('form');
            if (form) form.reset();

            document.getElementById('ModalBranch_Id').value = 0;
            document.getElementById('ModalBranch_Name').value = '';
            document.getElementById('ModalBranch_City').value = '';
            document.getElementById('ModalBranch_Street').value = '';
            document.getElementById('ModalBranch_House').value = '';
            document.getElementById('ModalBranch_Phone').value = '';

            const branchPhoto = document.getElementById('BranchPhoto');
            if (branchPhoto) branchPhoto.value = '';

            const title = document.querySelector('#branchModal h5');
            if (title) title.innerText = 'Филиал';

            clearValidation(modal);
        }

        function resetFacilityModal() {
            const modal = document.getElementById('facilityModal');
            if (!modal) return;

            const form = modal.querySelector('form');
            if (form) form.reset();

            document.getElementById('ModalFacility_Id').value = 0;
            document.getElementById('ModalFacility_BranchId').value = '';
            document.getElementById('ModalFacility_Name').value = '';

            var numField = document.getElementById('ModalFacility_Num');
            if (numField) numField.value = '';

            document.getElementById('ModalFacility_Type').value = 'Футбольное поле';
            document.getElementById('ModalFacility_Cap').value = '';
            document.getElementById('ModalFacility_Stat').value = 'Активен';
            document.getElementById('ModalFacility_Cost').value = '';

            clearValidation(modal);
        }

        function clearValidation(modal) {
            modal.querySelectorAll('.is-invalid').forEach(el => el.classList.remove('is-invalid'));
            modal.querySelectorAll('.is-valid').forEach(el => el.classList.remove('is-valid'));
        }

        function setupModalReset(modalId, resetCallback) {
            const modal = document.getElementById(modalId);
            if (!modal) return;

            modal.addEventListener('hidden.bs.modal', function () {
                resetCallback();
            });
        }

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                closeBranchDetails();
            }
        });
    </script>
}