@page
@model FootballSchool.Pages.ContactsModel
@{
    ViewData["Title"] = "Контакты";
    bool isEditMode = Request.Query["edit"] == "true" && User.IsInRole("Admin");
}

<div class="card p-4" style="border-radius: 12px;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success mb-4"><i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]</div>
    }

    @if (isEditMode)
    {
        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-bold">Редактирование текста (Контакты)</label>
                <textarea asp-for="PageContent" id="html-editor" class="form-control" rows="20"></textarea>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Сохранить изменения
                </button>
                <a href="/Contacts" class="btn btn-secondary">
                    Отмена
                </a>
            </div>
        </form>
    }
    else
    {
        @if (User.IsInRole("Admin"))
        {
            <div class="d-flex justify-content-end mb-4 pb-3 border-bottom">
                <a href="/Contacts?edit=true" class="btn btn-outline-primary">
                    <i class="fas fa-edit"></i> Редактировать страницу
                </a>
            </div>
        }

        <div class="page-rendered-content" style="font-size: 16px; line-height: 1.6;">
            @Html.Raw(Model.PageContent)
        </div>
    }
</div>

@section Scripts {
    @if (isEditMode)
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/tinymce/6.8.2/tinymce.min.js" referrerpolicy="origin"></script>
        <script>
            const isDarkMode = document.body.classList.contains('dark-theme');

            tinymce.init({
                selector: '#html-editor',
                plugins: 'image link lists table media',
                toolbar: 'undo redo | blocks | bold italic underline | alignleft aligncenter alignright | bullist numlist | link image media',
                menubar: false,
                branding: false,
                promotion: false,
                skin: isDarkMode ? 'oxide-dark' : 'oxide',
                content_css: isDarkMode ? 'dark' : 'default',
                content_style: 'body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; font-size: 16px; line-height: 1.6; background-color: ' + (isDarkMode ? '#1e293b' : '#ffffff') + '; color: ' + (isDarkMode ? '#f8fafc' : '#374151') + '; }'
            });
        </script>
    }
}