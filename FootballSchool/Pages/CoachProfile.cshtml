@page "{id:int?}"
@model FootballSchool.Pages.CoachProfileModel
@{
    ViewData["Title"] = "Профиль тренера";
}

@section Styles {
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        .page-header { display: none; }
        .page-content { padding: 0 !important; margin: 0 !important; }

        .coach-profile-container { background-color: #ffffff; min-height: 100vh; position: relative; }
        .profile-banner { background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%); height: 180px; position: relative; }
        .profile-section { padding: 0 40px; position: relative; }
        
        .profile-avatar {
            width: 140px; height: 140px; border-radius: 50%; border: 5px solid #ffffff;
            position: absolute; top: -70px; left: 40px;
            background: linear-gradient(135deg, #E0E7FF 0%, #C7D2FE 100%);
            display: flex; align-items: center; justify-content: center;
            font-size: 36px; color: #2563EB; font-weight: bold;
        }

        .profile-info {
            padding-top: 90px; display: flex; justify-content: space-between; align-items: flex-start;
            padding-bottom: 24px; border-bottom: 1px solid #e5e7eb; position: relative;
        }

        .profile-details h2 { font-size: 28px; font-weight: 600; color: #111827; margin-bottom: 8px; }
        .profile-details p { font-size: 14px; color: #6b7280; margin-bottom: 4px; }
        .status-badge { padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: 500; display: inline-block; margin-bottom: 12px; }
        .status-free { background-color: #d1fae5; color: #065f46; }
        .status-busy { background-color: #fce7f3; color: #6b21a8; }

        .admin-actions { display: flex; gap: 12px; position: absolute; right: 0; top: 90px; }
        .btn-edit, .btn-delete {
            padding: 8px 16px; border-radius: 8px; font-size: 14px; font-weight: 500;
            cursor: pointer; display: flex; align-items: center; gap: 6px; border: 1px solid transparent;
        }
        .btn-edit { background: white; border-color: #D1D5DB; color: #374151; }
        .btn-edit:hover { background: #F3F4F6; }
        .btn-delete { background: #FEE2E2; color: #DC2626; border-color: #FECACA; }
        .btn-delete:hover { background: #FCA5A5; color: white; }

        .tabs { display: flex; gap: 40px; padding: 0 40px; margin-top: 24px; border-bottom: 1px solid #e5e7eb; }
        .tab { padding: 12px 0; font-size: 14px; font-weight: 500; color: #6b7280; cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.2s; margin-bottom: -1px; }
        .tab.active { color: #2563eb; border-bottom-color: #2563eb; }

        .content-section { padding: 32px 40px; display: none; }
        .content-section.active { display: block; }
        .section-title { font-size: 20px; font-weight: 600; color: #111827; margin-bottom: 24px; }

        .group-card { background-color: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 20px; margin-bottom: 16px; }
        .group-card h3 { font-size: 16px; font-weight: 600; color: #111827; margin-bottom: 8px; }
        .group-info { font-size: 14px; color: #6b7280; margin-bottom: 4px; }
    </style>
}

<div class="coach-profile-container">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success m-3 position-absolute w-100" style="z-index: 100; top: 0;"><i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]</div>
    }

    <div class="profile-banner"></div>

    @if (Model.Profile != null)
    {
        <div class="profile-section">
            <div class="profile-avatar">@Model.Profile.Initials</div>

            <div class="profile-info">
                <div class="profile-details">
                    <span class="status-badge @Model.Profile.StatusClass">@Model.Profile.StatusText</span>
                    <h2>@Model.Profile.FullName</h2>
                    <p><strong>Специализация:</strong> @Model.Profile.Specialty</p>
                    <p><strong>Квалификация:</strong> @Model.Profile.Qualification</p>
                    <p><strong>График:</strong> @Model.Profile.Schedule</p>
                    <p><strong>Ставка:</strong> @Model.Profile.Salary ₽</p>
                </div>
                
                <div class="admin-actions">
                    <button class="btn-edit" data-bs-toggle="modal" data-bs-target="#editCoachModal">
                        <i class="fas fa-edit"></i> Изменить
                    </button>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@Model.Profile.CoachId" onsubmit="return confirm('Удалить профиль тренера безвозвратно?');">
                        <button type="submit" class="btn-delete">
                            <i class="fas fa-trash"></i> Удалить
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="tabs">
            <div class="tab active" data-tab="groups">Закрепленные группы</div>
            <div class="tab" data-tab="achievements">Награды</div>
        </div>

        <div class="content-section active" id="groups-section">
            <h2 class="section-title">Группы под руководством тренера</h2>
            
            @if (!Model.Profile.Groups.Any())
            {
                <p class="text-muted">У данного тренера пока нет закрепленных групп.</p>
            }
            else
            {
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
                    @foreach (var group in Model.Profile.Groups)
                    {
                        <div class="group-card">
                            <h3>@group.CategoryName</h3>
                            <div class="group-info"><i class="fas fa-users text-primary me-2"></i> @group.StudentsCount участников</div>
                            <div class="group-info"><i class="fas fa-clock text-primary me-2"></i> Расписание: @group.ScheduleInfo</div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="content-section" id="achievements-section">
            <h2 class="section-title">Достижения</h2>
            <p class="text-muted">Модуль достижений в разработке.</p>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h4 class="text-muted">Тренер не найден</h4>
            <a href="/Coaches" class="btn btn-primary mt-3">К списку тренеров</a>
        </div>
    }
</div>

@if (Model.Profile != null)
{
    <div class="modal fade" id="editCoachModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <form method="post" asp-page-handler="Edit">
                    <div class="modal-header">
                        <h5 class="modal-title">Редактирование профиля</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" asp-for="EditCoach.CoachId" />
                        <h6 class="mb-3 text-primary border-bottom pb-2">Основные данные</h6>
                        <div class="row">
                            <div class="col-md-4 mb-3"><label>Фамилия</label><input asp-for="EditCoach.SurnameCoach" class="form-control" required /></div>
                            <div class="col-md-4 mb-3"><label>Имя</label><input asp-for="EditCoach.NameCoach" class="form-control" required /></div>
                            <div class="col-md-4 mb-3"><label>Отчество</label><input asp-for="EditCoach.MiddleCoach" class="form-control" /></div>

                            <div class="col-md-6 mb-3"><label>Специализация</label><input asp-for="EditCoach.SpecialtyCoach" class="form-control" required /></div>
                            <div class="col-md-6 mb-3"><label>Квалификация</label><input asp-for="EditCoach.QualificationCoach" class="form-control" required /></div>
                        </div>

                        <h6 class="mb-3 mt-3 text-primary border-bottom pb-2">Условия работы</h6>
                        <div class="row">
                            <div class="col-md-6 mb-3"><label>Ставка / Зарплата (₽)</label><input asp-for="EditCoach.SalaryCoach" type="number" step="0.01" class="form-control" /></div>
                            <div class="col-md-6 mb-3"><label>График работы</label><input asp-for="EditCoach.ScheduleCoach" class="form-control" /></div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary" style="background:#2563EB; border:none;">Сохранить изменения</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.querySelectorAll('.tab').forEach(tab => {
            tab.addEventListener('click', function() {
                document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
                this.classList.add('active');
                document.querySelectorAll('.content-section').forEach(section => {
                    section.classList.remove('active');
                });
                const tabName = this.getAttribute('data-tab');
                document.getElementById(tabName + '-section').classList.add('active');
            });
        });
    </script>
}