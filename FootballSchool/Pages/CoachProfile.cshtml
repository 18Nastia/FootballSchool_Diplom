@page "{id:int?}"
@model FootballSchool.Pages.CoachProfileModel
@{
    ViewData["Title"] = "Профиль тренера";
}

@section Styles {
    <link rel="stylesheet" href="~/css/coach-profile.css" asp-append-version="true" />
}

<div class="coach-profile-page">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success mb-3">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    }

    @if (Model.Profile != null)
    {
        <div class="profile-card">
            <div class="profile-avatar-block">
                @if (!string.IsNullOrEmpty(Model.Profile.PhotoPath))
                {
                    <div class="avatar-circle" onclick="previewImage('@Model.Profile.PhotoPath')">
                        <img src="@Model.Profile.PhotoPath"
                             alt="@Model.Profile.FullName"
                             onerror="this.style.display='none'; this.parentElement.innerHTML='@Model.Profile.Initials';" />
                    </div>
                }
                else
                {
                    <div class="avatar-circle">@Model.Profile.Initials</div>
                }

                <span class="status-badge @Model.Profile.StatusClass">@Model.Profile.StatusText</span>
            </div>

            <div class="profile-info">
                <div class="profile-name">@Model.Profile.FullName</div>

                <div class="info-grid">
                    <div class="info-item">
                        <i class="fas fa-futbol"></i>
                        <div>
                            <div class="info-label">Специализация</div>
                            <div class="info-value">@Model.Profile.Specialty</div>
                        </div>
                    </div>

                    <div class="info-item">
                        <i class="fas fa-certificate"></i>
                        <div>
                            <div class="info-label">Квалификация</div>
                            <div class="info-value">@Model.Profile.Qualification</div>
                        </div>
                    </div>

                    <div class="info-item">
                        <i class="fas fa-clock"></i>
                        <div>
                            <div class="info-label">График работы</div>
                            <div class="info-value">@Model.Profile.Schedule</div>
                        </div>
                    </div>

                    <div class="info-item">
                        <i class="fas fa-wallet"></i>
                        <div>
                            <div class="info-label">Ставка / зарплата</div>
                            <div class="info-value">@Model.Profile.Salary ₽</div>
                        </div>
                    </div>
                </div>
            </div>

            @if (User.IsInRole("Admin"))
            {
                <div class="admin-actions">
                    <button class="btn-edit" data-bs-toggle="modal" data-bs-target="#editCoachModal">
                        <i class="fas fa-edit"></i> Изменить
                    </button>

                    <form method="post" asp-page-handler="Delete" asp-route-id="@Model.Profile.CoachId" onsubmit="return confirm('Удалить профиль тренера безвозвратно?');">
                        <button type="submit" class="btn-delete">
                            <i class="fas fa-trash"></i> Удалить
                        </button>
                    </form>
                </div>
            }
        </div>

        <div class="tabs">
            <button class="tab-btn active" type="button" data-tab="groups-section">
                <i class="fas fa-users"></i> Закрепленные группы
            </button>
            <button class="tab-btn" type="button" data-tab="achievements-section">
                <i class="fas fa-award"></i> Квалификация и достижения
            </button>
        </div>

        <div class="content-section active" id="groups-section">
            <h3 class="section-title">Группы под руководством тренера</h3>

            @if (!Model.Profile.Groups.Any())
            {
                <p class="text-muted">У данного тренера пока нет закрепленных групп с запланированными тренировками.</p>
            }
            else
            {
                <div class="groups-grid">
                    @foreach (var group in Model.Profile.Groups)
                    {
                        <div class="group-card">
                            <div class="group-card-icon">
                                <i class="fas fa-users"></i>
                            </div>
                            <div class="group-details">
                                <h4>@group.CategoryName</h4>
                                <p>@group.StudentsCount участников</p>
                                <p>@group.ScheduleInfo</p>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="content-section" id="achievements-section">
            <h3 class="section-title">Профиль достижений</h3>

            @if (!Model.Profile.Awards.Any())
            {
                <p class="text-muted">У данного тренера пока не заполнены квалификации или отсутствуют проведенные тренировки.</p>
            }
            else
            {
                <div class="awards-grid">
                    @foreach (var award in Model.Profile.Awards)
                    {
                        <div class="award-card">
                            <div class="award-icon">
                                <i class="@award.IconClass"></i>
                            </div>
                            <div class="award-details">
                                <h4>@award.Title</h4>
                                <div class="award-date">@award.Date</div>
                                <p>@award.Description</p>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h4 class="text-muted">Тренер не найден</h4>
            <a href="/Coaches" class="btn btn-primary mt-3">К списку тренеров</a>
        </div>
    }
</div>

@if (Model.Profile != null && User.IsInRole("Admin"))
{
    <div class="modal fade" id="editCoachModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <form method="post" asp-page-handler="Edit">
                    <div class="modal-header">
                        <h5 class="modal-title">Редактирование профиля</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" asp-for="EditCoach.CoachId" />

                        <h6 class="mb-3 text-primary border-bottom pb-2">Основные данные</h6>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label>Фамилия</label>
                                <input asp-for="EditCoach.SurnameCoach" class="form-control" required />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label>Имя</label>
                                <input asp-for="EditCoach.NameCoach" class="form-control" required />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label>Отчество</label>
                                <input asp-for="EditCoach.MiddleCoach" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label>Специализация</label>
                                <input asp-for="EditCoach.SpecialtyCoach" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label>Квалификация</label>
                                <input asp-for="EditCoach.QualificationCoach" class="form-control" required />
                            </div>
                        </div>

                        <h6 class="mb-3 mt-3 text-primary border-bottom pb-2">Условия работы</h6>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label>Ставка / Зарплата (₽)</label>
                                <input asp-for="EditCoach.SalaryCoach" type="number" step="0.01" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label>График работы</label>
                                <input asp-for="EditCoach.ScheduleCoach" class="form-control" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary profile-submit-btn">
                            Сохранить изменения
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<div class="modal fade" id="imagePreviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content bg-transparent border-0">
            <div class="modal-header border-0 p-0 justify-content-end mb-2">
                <button type="button" class="btn-close image-preview-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center p-0">
                <img id="fullSizeImage" src="" alt="Preview" class="full-size-image" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.tab-btn').forEach(x => x.classList.remove('active'));
                this.classList.add('active');

                document.querySelectorAll('.content-section').forEach(section => {
                    section.classList.remove('active');
                });

                const tabId = this.getAttribute('data-tab');
                document.getElementById(tabId).classList.add('active');
            });
        });

        function previewImage(src) {
            if (!src) return;
            document.getElementById('fullSizeImage').src = src;
            const previewModal = new bootstrap.Modal(document.getElementById('imagePreviewModal'));
            previewModal.show();
        }
    </script>
}